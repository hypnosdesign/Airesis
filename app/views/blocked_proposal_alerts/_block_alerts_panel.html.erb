<div id="block-alerts-panel">
  <% if current_user %>
    <% if @blocked_alerts %>
      <%= link_to unlock_proposal_blocked_proposal_alerts_path(@proposal), data: { turbo_method: :post } , class: "btn" do %>
        <i class="fa-solid fa-bell"></i>
        <%= t('pages.proposals.show.enable_alerts') %>
      <% end %>
    <% else %>
      <%= link_to block_proposal_blocked_proposal_alerts_path(@proposal), data: { turbo_method: :post }, class: "btn" do %>
        <i class="fa-solid fa-bell-slash"></i>
        <%= t('pages.proposals.show.disable_alerts') %>
      <% end %>
    <% end %>
  <% end %>
</div>
