<% @extend = true %>
<h1><%= @tag %></h1>
<div role="tablist" class="tabs tabs-bordered">
  <a role="tab" class="tab tab-active" href="#proposals"><%= t('pages.tags.proposals_tab') %></a>
  <a role="tab" class="tab" href="#posts"><%= t('pages.tags.posts_tab') %></a>
  <a role="tab" class="tab" href="#groups"><%= t('pages.tags.groups_tab') %></a>
</div>
<div class="mt-4">
  <div id="proposals">
    <h2><%= t('pages.tags.list_proposals_with_tag') %></h2>
    <% if @proposals.size == 0 %>
      <div class="Proposal">
        <p><%= t('pages.tags.no_proposals_with_tag') %></p>
      </div>
    <% else %>
      <ul class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <% @proposals.each do |proposal| %>
          <%= render 'proposals/proposal_list_element', proposal_list_element_for_mustache(proposal) %>
        <% end %>
      </ul>
    <% end %>
  </div>
  <div id="posts">
    <h2><%= t('pages.tags.list_posts_with_tag') %></h2>
    <% if @blog_posts.size == 0 %>
      <div class="blogPost">
        <p><%= t('pages.tags.no_posts_with_tag') %></p>
      </div>
    <% else %>
      <% @blog_posts.each do |blog_post| %>
        <div>
          <%= render 'blog_posts/blog_post', blog_post: blog_post %>
        </div>
      <% end %>
    <% end %>
  </div>
  <div id="groups">
    <h2><%= t('pages.tags.list_groups_with_tags') %></h2>
    <% if @groups.size == 0 %>
      <p><%= t('pages.tags.no_groups_with_tag') %></p>
    <% else %>
      <ul class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-4">
        <%= render collection: @groups, partial: 'groups/group_tag', as: 'group' %>
      </ul>
    <% end %>
  </div>
</div>
<% content_for :left_panel do %>
  <div class="card bg-base-200 p-4">
    <h4><%= t('pages.tags.show.related_title') %></h4>
  </div>
  <div>
    <% @similars.each do |tag| %>
      <span class="badge tag">
        <a href="<%= tag_path tag.text %>"><%= tag.text %></a>
      </span>
    <% end %>
  </div>
<% end %>
