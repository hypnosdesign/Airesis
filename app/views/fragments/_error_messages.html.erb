<% if resource.errors.any? %>
  <div id="errorExplanation" class="alert alert-error">
    <% title ||= nil %>
    <% if title %>
      <h3><%= title %></h3>
    <% end %>
    <ul>
      <% resource.errors.each do |attr, msg| %>
        <% if resource.errors[attr].first == msg %>
          <li><b><%= resource.class.human_attribute_name(attr) %></b>: <%= msg %></li>
        <% end %>
      <% end %>
    </ul>
  </div>
<% end %>
