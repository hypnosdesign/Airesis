<%= turbo_stream.replace "quorum_modal" do %>
  <dialog id="quorum_modal" data-controller="modal" class="modal">
    <div class="modal-box shadow-brutal border-2 border-base-content max-w-3xl">
      <%= render partial: "quorums/form", locals: { button_name: t("buttons.update") } %>
    </div>
    <form method="dialog" class="modal-backdrop" data-action="click->modal#backdropClose">
      <button>close</button>
    </form>
  </dialog>
<% end %>
