<div id="roles_panel_container">
  <% @participation_roles.each_with_index do |role, idx| %>
    <div class="collapse collapse-arrow bg-base-200 mb-2 border border-base-300">
      <input type="radio" name="roles-accordion" <%= 'checked' if idx == 0 %> />
      <div class="collapse-title font-medium">
        <%= role.name %>
        <% if role.id == @group.participation_role_id %>
          <span class="badge badge-sm badge-primary ml-2">default</span>
        <% end %>
      </div>
      <div class="collapse-content">
        <div class="flex gap-2 mb-4 justify-end">
          <%= link_to edit_group_participation_role_url(@group, role), class: 'btn btn-sm' do %>
            <i class="fa-solid fa-pencil"></i>
            <%= t('buttons.edit') %>
          <% end %>
          <%= link_to group_participation_role_url(@group, role), data: { turbo_method: :delete, turbo_confirm: t('pages.groups.edit_permissions.confirm_role_deletion') }, class: 'btn btn-sm btn-error' do %>
            <i class="fa-regular fa-trash-can"></i>
            <%= t('buttons.delete') %>
          <% end %>
        </div>
        <h4 class="font-semibold mb-2"><%= role.description %></h4>
        <%= simple_form_for [@group, role] do |f| %>
          <input type="hidden" name="no_refresh" value="1">
          <%= f.input :view_proposals, label: I18n.t("db.group_actions.view_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :participate_proposals, label: I18n.t("db.group_actions.participate_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :vote_proposals, label: I18n.t("db.group_actions.vote_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :insert_proposals, label: I18n.t("db.group_actions.insert_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :support_proposals, label: I18n.t("db.group_actions.support_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :view_documents, label: I18n.t("db.group_actions.view_documents.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :manage_documents, label: I18n.t("db.group_actions.manage_documents.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :create_events, label: I18n.t("db.group_actions.create_events.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :choose_date_proposals, label: I18n.t("db.group_actions.choose_date_proposals.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :write_to_wall, label: I18n.t("db.group_actions.write_to_wall.description"), input_html: { data: { action_abilitation: '' } } %>
          <%= f.input :accept_participation_requests, label: I18n.t("db.group_actions.accept_participation_requests.description"), input_html: { data: { action_abilitation: '' } } %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
