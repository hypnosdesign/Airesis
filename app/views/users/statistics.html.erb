<%= ::Temple::Utils.escape_html((@user.last_sign_in_at)) %>
</span></p><p>
<b>
<%= ::Temple::Utils.escape_html((t('.integrated_count'))) %>
</b><span class="info">
<%= ::Temple::Utils.escape_html((@integrated_count)) %>
</span></p><p>
<b>
<%= ::Temple::Utils.escape_html((t('.spam_count'))) %>
</b><span class="info">
<%= ::Temple::Utils.escape_html((@spam_count)) %>
</span></p><p>
<b>
<%= ::Temple::Utils.escape_html((t('.noisy_count'))) %>
</b><span class="info">
<%= ::Temple::Utils.escape_html((@noisy_count)) %>
</span></p><p>
<b>
<%= ::Temple::Utils.escape_html((t('.total_count'))) %>
