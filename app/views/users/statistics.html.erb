</span></p><p>
<b>
<%= ::Temple::Utils.escape_html((t('.good_writer'))) %>
</b><span class="info">
<div class="progress small-4">
 <span class="meter" style="width: 
<%= ::Temple::Utils.escape_html((((1+((@integrated_count.to_f/@contributes_count.to_f)**(0.5) - (@spam_count.to_f/@comments_count.to_f)**(1.to_f/3.to_f)))/2)*100)) %>
%">
</div></span><%= ::Temple::Utils.escape_html((((1+((@integrated_count.to_f/@contributes_count.to_f)**(0.5) - (@spam_count.to_f/@comments_count.to_f)**(1.to_f/3.to_f)))/2)*100)) %>
 % 
</p></div><p>
<b>
<%= ::Temple::Utils.escape_html((t('.good_proposals_writer'))) %>
</b><span class="info">
<div class="progress small-4">
 <span class="meter" style="width: 
<%= ::Temple::Utils.escape_html((((1+(((0.8*@accepted_count)+(0.2*(@voted_count - @abandoned_count)))/(@voted_count+@abandoned_count)))/2)*100)) %>
%">
</div></span><%= ::Temple::Utils.escape_html((((1+(((0.8*@accepted_count)+(0.2*(@voted_count - @abandoned_count)))/(@voted_count+@abandoned_count)))/2)*100)) %>
 % 
</p><% if @user == current_user && @user.user_votes.count > 0
 %><div class="card">

</div><h2>
<%= ::Temple::Utils.escape_html((t('pages.users.show.votations_title'))) %>
</h2><table id="votations_table">
<thead>

</thead></table><th>
<%= ::Temple::Utils.escape_html((t('pages.users.show.proposal_column'))) %>
</th><th>
<%= ::Temple::Utils.escape_html((t('pages.users.show.votation_date_column'))) %>
</th><th>
vote_sortable
</th><th>
<%= ::Temple::Utils.escape_html((t('pages.users.show.vote_column'))) %>
</th><tbody>
<% @user.user_votes.includes(:vote_type, proposal: :groups).each do |vote|
 %><tr>
<td>
<%= ::Temple::Utils.escape_html((vote.proposal ? (link_to_proposal vote.proposal) : '')) %>
</td><td>
<%= ::Temple::Utils.escape_html((l vote.created_at)) %>
</td><td>
<%= ::Temple::Utils.escape_html((vote.created_at.to_i)) %>
</td><td>
<%= ::Temple::Utils.escape_html((vote.vote_type ? vote.vote_type.description : t('pages.users.show.secret_vote'))) %>
</td></tr><% end %></tbody><script type="text/javascript">
 $('#votations_table').dataTable({ "bPaginate": false, "bFilter": false, "bSearchable": false, "bInfo": false, "aaSorting": [ [1, 'desc'] ], "aoColumns": [null, {"iDataSort": 2}, {"bVisible": false}, null] }); 
</script><% end; content_for :left_panel do
if current_user
 %><%= ::Temple::Utils.escape_html((render partial: 'users/preferences_panel')) %>
<% end; end %>
