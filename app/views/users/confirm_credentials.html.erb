<% @page_title = t('.title') %>

<div class="card bg-base-200 p-4 mb-4">
  <h2 class="text-xl font-bold mb-2"><%= @page_title %></h2>
  <p><%= t('.instructions_html') %></p>
</div>

<div class="card bg-base-200 p-4">
  <div class="flex flex-wrap gap-4">
    <div class="w-full md:w-1/4">
      <%= avatar(@orig, size: 200) %>
    </div>
    <div class="flex-1">
      <%= simple_form_for(:user, url: join_accounts_users_path) do |f| %>
        <%= f.input :email, label: 'Email', readonly: true, disabled: true %>
        <%= f.input :password %>
        <div class="flex gap-2 mt-4">
          <%= button_tag type: :submit, class: 'btn btn-primary' do %>
            <i class="fa-solid fa-check"></i>
            <%= t('buttons.join_accounts') %>
          <% end %>
          <%= link_to t('buttons.cancel'), root_path, class: 'btn' %>
          <%= link_to t('pages.home.index.forgot_password'), new_user_password_path, class: 'link' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
