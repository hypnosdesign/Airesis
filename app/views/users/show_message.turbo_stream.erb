<%= turbo_stream.replace "message_modal" do %>
  <dialog id="message_modal" data-controller="modal" class="modal">
    <div class="modal-box shadow-brutal border-2 border-base-content">
      <%= render "users/message" %>
    </div>
    <form method="dialog" class="modal-backdrop" data-action="click->modal#backdropClose">
      <button>close</button>
    </form>
  </dialog>
<% end %>
