<div class="bg-base-100 border-2 border-base-content/15 p-6 mb-6">
  <div class="flex items-center gap-3 mb-6">
    <div class="bg-primary/10 text-primary p-2">
      <i class="fa-solid fa-id-card"></i>
    </div>
    <div>
      <h2 class="font-bold text-lg">
        <%= t('pages.users.show.profile_info') %>
        <%= t('pages.users.show.profile_info_unconfirmed') unless @user.confirmed? %>
      </h2>
      <p class="text-[11px] text-base-content/40"><%= t('pages.users.show.profile_info_desc', default: 'Informazioni personali e contatti.') %></p>
    </div>
    <% if @user == current_user %>
      <div class="image-container ml-auto">
        <a class="btn btn-sm btn-outline font-bold"><i class="fa-solid fa-camera mr-1"></i> <%= t('pages.users.show.edit_image') %></a>
      </div>
    <% end %>
  </div>

  <div class="divide-y divide-base-content/10">
    <div id="name_profile" class="profile_element flex items-center gap-4 py-3 px-2 hover:bg-base-200 cursor-pointer">
      <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.name_label') %></span>
      <span class="font-medium"><%= h @user.name %></span>
      <% if current_user == @user %>
        <i class="fa-solid fa-pen-to-square text-base-content/20 ml-auto text-sm"></i>
      <% end %>
    </div>

    <div id="surname_profile" class="profile_element flex items-center gap-4 py-3 px-2 hover:bg-base-200 cursor-pointer">
      <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.surname_label') %></span>
      <span class="font-medium"><%= h @user.surname %></span>
      <% if current_user == @user %>
        <i class="fa-solid fa-pen-to-square text-base-content/20 ml-auto text-sm"></i>
      <% end %>
    </div>

    <% if current_user == @user %>
      <div id="email_profile" class="profile_element flex items-center gap-4 py-3 px-2 hover:bg-base-200 cursor-pointer">
        <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.email_label') %></span>
        <span class="font-medium">
          <%= @user.email %>
          <% if @user.unconfirmed_email %>
            <span class="badge badge-sm badge-warning font-bold ml-2"><%= @user.unconfirmed_email %> - <%= t('pages.users.show.to_be_confirmed') %></span>
          <% end %>
        </span>
        <i class="fa-solid fa-pen-to-square text-base-content/20 ml-auto text-sm"></i>
      </div>

      <div id="password_profile" class="profile_element flex items-center gap-4 py-3 px-2 hover:bg-base-200 cursor-pointer">
        <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.password_label') %></span>
        <span class="font-medium">*****</span>
        <i class="fa-solid fa-pen-to-square text-base-content/20 ml-auto text-sm"></i>
      </div>
    <% end %>

    <% if @user.show_urls && ::Configuration::socialnetwork_active %>
      <% if @user.has_provider?(Authentication::FACEBOOK) %>
        <div id="facebook_profile" class="profile_element_no_click flex items-center gap-4 py-3 px-2">
          <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.facebook_url_label') %></span>
          <span class="font-medium">
            <%= link_to @user.facebook_page_url, @user.facebook_page_url, target: '_blank', class: 'link link-primary' if @user.facebook_page_url.present? %>
          </span>
        </div>
      <% end %>
      <% if @user.has_provider?(Authentication::GOOGLE) && @user.google_page_url.present? %>
        <div id="google_profile" class="profile_element_no_click flex items-center gap-4 py-3 px-2">
          <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.google_url_label') %></span>
          <span class="font-medium">
            <%= link_to(@user.google_page_url, @user.google_page_url, target: '_blank', rel: 'author', class: 'link link-primary') %>
          </span>
        </div>
      <% end %>
      <% if @user.has_provider?(Authentication::TWITTER) && @user.twitter_page_url.present? %>
        <div id="twitter_profile" class="profile_element_no_click flex items-center gap-4 py-3 px-2">
          <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.twitter_url') %></span>
          <span class="font-medium">
            <%= link_to @user.twitter_page_url, @user.twitter_page_url, target: '_blank', class: 'link link-primary' %>
          </span>
        </div>
      <% end %>
    <% end %>

    <div id="confirmed_at_profile" class="profile_element_no_click flex items-center gap-4 py-3 px-2">
      <span class="text-[11px] text-base-content/40 font-bold uppercase w-28 shrink-0"><%= t('pages.users.show.registered_from') %></span>
      <span class="font-medium"><%= l(@user.confirmed? ? @user.confirmed_at : @user.created_at) %></span>
    </div>
  </div>
</div>

<% if current_user == @user %>
  <dialog id="img_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <div class="flex flex-wrap">
          <div class="w-full lg:w-1/2">
            <h2 class="text-lg font-bold mb-2"><%= t('pages.users.show.load_image') %></h2>
            <div class="alert alert-info mb-4">
              <p><%= t('pages.users.show.max_file_size') %></p>
            </div>
            <%= f.input :avatar, required: true, input_html: { accepted: 'image/jpeg,image/png', data: { fv_trigger: 'change', fv_file: true, fv_file_maxsize: UPLOAD_LIMIT_IMAGES } } %>
            <a href="#" class="btn" onclick="document.getElementById('img_modal').close(); return false;"><%= t('buttons.cancel') %></a>
            <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <script>
    document.getElementById('name_profile').addEventListener('click', function () { document.getElementById('name_modal').showModal(); });
    document.getElementById('surname_profile').addEventListener('click', function () { document.getElementById('surname_modal').showModal(); });
    document.getElementById('email_profile').addEventListener('click', function () { document.getElementById('email_modal').showModal(); });
    <% if params[:insert_email] %>
      document.getElementById('email_profile').click();
    <% end %>
    document.getElementById('password_profile').addEventListener('click', function () { document.getElementById('password_modal').showModal(); });
    document.querySelector('.image-container a').addEventListener('click', function () { document.getElementById('img_modal').showModal(); });
    document.querySelectorAll('.profile_element').forEach(function (el) { el.style.cursor = 'pointer'; });
  </script>
<% else %>
  <script>
    document.querySelectorAll('.profile_element').forEach(function (el) {
      el.classList.add('profile_element_no_click');
      el.classList.remove('profile_element');
    });
  </script>
<% end %>
