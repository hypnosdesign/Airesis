<% @page_title = @user.fullname %>

<% content_for :html_options do %>
  itemscope itemtype="http://data-vocabulary.org/Person"
<% end %>

<% content_for :head do %>
  <meta itemprop="name" content="<%= @user.fullname %>"/>
  <meta itemprop="nickname" content="<%= @user.fullname %>"/>
  <meta itemprop="url" content="<%= "#{request.protocol}#{request.host_with_port}#{request.fullpath}" %>"/>
<% end %>

<div id="user_profile_container">
  <%= render partial: 'user_profile' %>
</div>

<% if @user == current_user && @user.group_participations.count > 0 %>
  <div class="card bg-base-200 p-4 mb-4">
    <% @group_participations = @user.group_participations.includes([:group, :participation_role, :user]) %>
    <h2 class="text-xl font-bold mb-2"><%= t('pages.users.show.groups_title') %></h2>
    <table id="participation_table" class="table">
      <thead>
        <tr>
          <th><%= t('pages.users.show.group_column') %></th>
          <th><%= t('pages.users.show.role_column') %></th>
          <th class="hidden md:table-cell"><%= t('pages.users.show.registered_from') %></th>
          <th>registered_from</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: 'users/group_participation', collection: @group_participations, as: :participation %>
      </tbody>
    </table>
  </div>
<% end %>

<% if current_user == @user %>
  <dialog id="name_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <div class="w-full lg:w-1/2">
          <%= f.input :name, size: 20, required: true %>
          <div class="flex gap-2 mt-2">
            <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('name_modal').close();" class="btn"/>
            <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="surname_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :surname, size: 20, required: true %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('surname_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="password_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :password, required: true, type: :password, label: t('pages.password.edit.new_password'), size: 20 %>
        <%= f.input :password_confirmation, required: true, type: :password, size: 20, label: t('pages.registration.confirm_password'), input_html: { data: { fv_identical_field: 'user[password]', fv_identical: true } } %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('password_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="email_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :email, label: t('pages.users.show.email_label'), size: 25, required: true %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('email_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>
<% end %>

<% content_for :left_panel do %>
  <% if current_user == @user %>
    <%= render partial: 'users/preferences_panel' %>
  <% end %>
<% end %>
