<% @page_title = @user.fullname %>

<% content_for :html_options do %>
  itemscope itemtype="http://data-vocabulary.org/Person"
<% end %>

<% content_for :head do %>
  <meta itemprop="name" content="<%= @user.fullname %>"/>
  <meta itemprop="nickname" content="<%= @user.fullname %>"/>
  <meta itemprop="url" content="<%= "#{request.protocol}#{request.host_with_port}#{request.fullpath}" %>"/>
<% end %>

<%# — Hero Banner — %>
<div class="bg-primary text-primary-content p-6 lg:p-8 mb-6 border-2 border-base-content/15 relative overflow-hidden">
  <i class="fa-solid fa-user absolute right-6 top-1/2 -translate-y-1/2 text-[120px] opacity-10"></i>
  <div class="relative z-10 flex items-center gap-6">
    <div class="border-2 border-primary-content/30">
      <%= avatar(@user, size: 96) %>
    </div>
    <div>
      <h1 class="text-3xl lg:text-4xl font-extrabold"><%= @user.fullname %></h1>
      <p class="text-[11px] text-primary-content/60 mt-1">
        <i class="fa-solid fa-calendar-check mr-1"></i>
        <%= t('pages.users.show.registered_from') %>: <%= l(@user.confirmed? ? @user.confirmed_at : @user.created_at) %>
      </p>
      <% if @user == current_user && ::Configuration::user_messages %>
        <%= link_to show_message_user_path(@user), class: 'btn btn-sm btn-outline border-primary-content/30 text-primary-content font-bold mt-3' do %>
          <i class="fa-solid fa-envelope mr-1"></i>
          <%= t('pages.users.show.send_message_button') %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# — Stats Row — %>
<% if @user == current_user %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-base-100 border-2 border-base-content/15 p-4 text-center">
      <p class="text-2xl font-extrabold"><%= @user.group_participations.count %></p>
      <p class="text-[11px] text-base-content/40 font-bold uppercase"><%= t('pages.users.show.groups_title', default: 'Gruppi') %></p>
    </div>
    <div class="bg-base-100 border-2 border-base-content/15 p-4 text-center">
      <p class="text-2xl font-extrabold"><%= @user.proposals.count %></p>
      <p class="text-[11px] text-base-content/40 font-bold uppercase"><%= t('pages.users.show.proposals_count', default: 'Proposte') %></p>
    </div>
    <div class="bg-base-100 border-2 border-base-content/15 p-4 text-center">
      <p class="text-2xl font-extrabold"><%= @user.proposal_comments.count %></p>
      <p class="text-[11px] text-base-content/40 font-bold uppercase"><%= t('pages.users.show.comments_count', default: 'Commenti') %></p>
    </div>
    <div class="bg-base-100 border-2 border-base-content/15 p-4 text-center">
      <p class="text-2xl font-extrabold"><%= @user.events.count %></p>
      <p class="text-[11px] text-base-content/40 font-bold uppercase"><%= t('pages.users.show.events_count', default: 'Eventi') %></p>
    </div>
  </div>
<% end %>

<%# — Profile Info — %>
<div id="user_profile_container">
  <%= render partial: 'user_profile' %>
</div>

<%# — Groups Table — %>
<% if @user == current_user && @user.group_participations.count > 0 %>
  <div class="bg-base-100 border-2 border-base-content/15 p-6 mb-6">
    <% @group_participations = @user.group_participations.includes([:group, :participation_role, :user]) %>
    <div class="flex items-center gap-3 mb-4">
      <div class="bg-secondary/10 text-secondary p-2">
        <i class="fa-solid fa-users"></i>
      </div>
      <div>
        <h2 class="font-bold text-lg"><%= t('pages.users.show.groups_title') %></h2>
        <p class="text-[11px] text-base-content/40"><%= @group_participations.count %> gruppi attivi</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table id="participation_table" class="table">
        <thead>
          <tr>
            <th><%= t('pages.users.show.group_column') %></th>
            <th><%= t('pages.users.show.role_column') %></th>
            <th class="hidden md:table-cell"><%= t('pages.users.show.registered_from') %></th>
            <th>registered_from</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <%= render partial: 'users/group_participation', collection: @group_participations, as: :participation %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<% if current_user == @user %>
  <dialog id="name_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <div class="w-full lg:w-1/2">
          <%= f.input :name, size: 20, required: true %>
          <div class="flex gap-2 mt-2">
            <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('name_modal').close();" class="btn"/>
            <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="surname_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :surname, size: 20, required: true %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('surname_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="password_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :password, required: true, type: :password, label: t('pages.password.edit.new_password'), size: 20 %>
        <%= f.input :password_confirmation, required: true, type: :password, size: 20, label: t('pages.registration.confirm_password'), input_html: { data: { fv_identical_field: 'user[password]', fv_identical: true } } %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('password_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>

  <dialog id="email_modal" class="modal">
    <div class="modal-box">
      <%= simple_form_for @user do |f| %>
        <%= f.input :email, label: t('pages.users.show.email_label'), size: 25, required: true %>
        <div class="flex gap-2 mt-2">
          <input type="button" value="<%= t('buttons.cancel') %>" onclick="document.getElementById('email_modal').close();" class="btn"/>
          <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">&times;</button></form>
    </div>
  </dialog>
<% end %>

<% content_for :left_panel do %>
  <% if current_user == @user %>
    <%= render partial: 'users/preferences_panel' %>
  <% end %>
<% end %>
