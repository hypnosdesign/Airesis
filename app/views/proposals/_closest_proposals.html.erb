<% unless @proposal.closest(@group.try(:id)).empty? %>
  <div class="card bg-base-200 p-3 mb-2">
    <h4 class="font-semibold mb-2"><%= t('pages.proposals.show.similar_proposals_title') %></h4>
    <div class="space-y-2">
      <% @proposal.closest.each do |p| %>
        <div class="card bg-base-100 p-2">
          <%= link_to_proposal p %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
