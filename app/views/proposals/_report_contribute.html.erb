<dialog id="report_contribute" class="modal">
  <div class="modal-box bg-base-100 max-w-2xl">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>

    <%= form_for 'proposal_comment', url: report_proposal_proposal_comments_path(@proposal), remote: true do |f| %>
      <%= cache "report_panel_#{I18n.locale}" do %>
        <input id="report_contribute_id" type="hidden" name="id" value="0">

        <h2 class="text-xl font-bold mb-4"><%= t('pages.proposals.report_contribute.mark_title') %></h2>
        <div class="card bg-info/10 border border-info p-4 mb-4">
          <p><%= raw t('pages.proposals.report_contribute.mark_description', num: CONTRIBUTE_MARKS) %></p>
        </div>
        <div class="space-y-2 mb-4">
          <% ProposalCommentReportType.softs.each do |r| %>
            <label class="flex items-center gap-2">
              <input type="radio" name="reason" value="<%= r.id %>" class="radio radio-sm">
              <span><%= r.description %></span>
            </label>
          <% end %>
        </div>
        <div class="flex gap-2 mb-6">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('report_contribute').close()"><%= t('buttons.cancel') %></button>
          <%= f.submit t('buttons.mark'), class: 'btn btn-primary', data: { disable_with: t('loading') } %>
        </div>

        <hr class="my-4">

        <h2 class="text-xl font-bold mb-4"><%= t('pages.proposals.report_contribute.report_title') %></h2>
        <div class="card bg-info/10 border border-info p-4 mb-4">
          <p><%= raw t('pages.proposals.report_contribute.report_description') %></p>
        </div>
        <div class="space-y-2 mb-4">
          <% ProposalCommentReportType.graves.each do |r| %>
            <label class="flex items-center gap-2">
              <input type="radio" name="reason" value="<%= r.id %>" class="radio radio-sm">
              <span><%= r.description %></span>
            </label>
          <% end %>
        </div>
        <div class="flex gap-2">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('report_contribute').close()"><%= t('buttons.cancel') %></button>
          <%= f.submit t('buttons.report'), class: 'btn btn-error', data: { disable_with: t('loading') } %>
        </div>
      <% end %>
    <% end %>
  </div>
</dialog>
