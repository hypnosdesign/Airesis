<span class="badge badge-info" style="width:80px">
  <h5 id="status"><%= @proposal.in_valutation? ? t('pages.proposals.show.during_debate') : @proposal.state.description %></h5>
</span>
<% if @proposal.is_anonima? %>
  <span class="badge badge-info" style="width:80px">
    <i class="fa-solid fa-user-secret nickname-panel"></i>
    <%= t('pages.proposals.show.anonimity_active') %>
  </span>
<% end %>
<% if @proposal.visible_outside? %>
  <span class="badge badge-info" style="width:80px">
    <i class="fa-solid fa-eye"></i>
    <%= t('info.proposal.public_visible_short') %>
  </span>
<% end %>
<div style="padding-bottom: 10px;">
  <%= t('pages.proposals.show.created_at_html', time: raw("<div class='date-creation'></div>"), date: (l @proposal.created_at)) %>
</div>
<% if @proposal.updated_at != @proposal.created_at %>
  <div class="mycont">
    <%= t('pages.proposals.show.updated_at_html', time: raw("<div class='date-update'></div>"), date: (l @proposal.updated_at)) %>
  </div>
<% end %>
<% unless @proposal.is_petition? %>
  <% if @proposal.in_valutation? %>
    <div id="condition_left" class="mycont">
      <% if @proposal.quorum.instance_of? OldQuorum %>
        <% if @proposal.quorum.time_left? %>
          <% if quorum.valutations_left? %>
            <div class="time_end">
              <%= t('pages.proposals.show.debate_ends_html') %>:
            </div>
            <div class="end-debate"></div>
            <div class="join_clause">
              <%= @proposal.quorum.or? ?
                t('pages.proposals.show.debate_ends_valutations_or') :
                t('pages.proposals.show.debate_ends_valutations_and') %>:
            </div>
            <b><%= @proposal.quorum.valutations_left %></b>
          <% else %>
            <div class="time_end">
              <%= t('pages.proposals.show.debate_ends_html') %>:
            </div>
            <div id="end_debate"></div>
          <% end %>
        <% elsif @proposal.quorum.valutations_left? %>
          <div class="time_end">
            <%= t('pages.proposals.show.debate_ends_valutations') %>:
          </div>
          <b><%= @proposal.quorum.valutations_left %></b>
        <% else %>
          End of debate:
          <br>
          rank superior to
          <b><%= @proposal.quorum.good_score %>%</b>
          <br>
          Abandoned:
          <br>
          rank inferior to
          <b><%= @proposal.quorum.bad_score %>%</b>
        <% end %>
      <% else %>
        <% if @proposal.quorum.time_left? %>
          <div class="time_end">
            <%= t('pages.proposals.show.debate_ends_html') %>:
          </div>
          <div class="end-debate"></div>
        <% else %>
          End of debate:
          <br>
          rank superior to
          <b><%= @proposal.quorum.good_score %>%</b>
          <br>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <% if @proposal.proposal_state_id == ProposalState::WAIT %>
    <div class="mycont">
      <%= t('pages.proposals.show.in_votation_html', start: (l @proposal.vote_period.starttime), end: (l @proposal.vote_period.endtime)) %>
    </div>
    <br>
  <% elsif @proposal.proposal_state_id == ProposalState::VOTING %>
    <div class="mycont">
      <%= t('pages.proposals.show.in_votation_until_html', date: raw("<div class='end-vote'></div>")) %>
    </div>
  <% end %>
<% end %>
