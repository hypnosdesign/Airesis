- if params[:search]
  b
    = params[:search]
  = link_to 'X',current_url(search: nil)
p
  = text_field_tag :search, params[:search], placeholder: t('pages.proposals.index.search_placeholder'), size: 30, class: 'field-by-text'
  = check_box_tag :or, 'or', params[:or].to_s != '', class: 'condition-for-text'
  = t('pages.proposals.index.search_words')
  br
  = link_to t('buttons.search'), current_url, class: 'btn search-by-text'
script[type="text/javascript"]
