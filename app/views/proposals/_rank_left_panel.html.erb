<% if can? :participate, @proposal
 %><div class="handscontainer">
<% if @my_vote
if @my_vote.to_sym == :positive
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/votedup')) %>
<% elsif @can_vote_again
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/voteup')) %>
<% end; if @my_vote.to_sym == :negative
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/voteddown')) %>
<% elsif @can_vote_again
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/votedown')) %>
<% end; elsif @can_vote_again
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/voteup')) %>
<%= ::Temple::Utils.escape_html((render partial: '/proposals/valutations/votedown')) %>
<% end %></div><div style="clear: both;">
</div><% end %>
