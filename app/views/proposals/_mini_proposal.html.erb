<div id="proposal<%= proposal.id %>" class="py-2 flex items-start gap-3">
  <div class="bg-base-200 w-8 h-8 flex items-center justify-center shrink-0 mt-0.5">
    <%= proposal_group_image_tag(proposal) %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="font-bold text-sm">
      <% if current_user %>
        <%= user_valutation_image(current_user, proposal) %>
      <% end %>
      <%= link_to_proposal proposal,
            style: (proposal.rejected? ? 'text-decoration: line-through;' : ''),
            title: (proposal.rejected? ? 'Rifiutata' : nil),
            class: 'hover:text-primary' %>
    </div>
    <% unless proposal.is_petition? %>
      <% mustache_proposal = proposal_for_mustache(proposal) %>
      <% if mustache_proposal['voting_or_voted?'] %>
        <%= render 'proposals/new_vote_bar', mustache_proposal %>
      <% else %>
        <%= render 'proposals/new_rank_bar', mustache_proposal %>
      <% end %>
    <% end %>
    <% if current_user %>
      <% count = proposal.alerts_count.to_i %>
      <% if count > 0 %>
        <%= link_to proposal, class: "badge badge-warning badge-sm font-bold", data: { load: true, proposal_id: proposal.id } do %>
          <i class="fa-solid fa-bell mr-1"></i> <%= count %>
        <% end %>
      <% end %>
    <% end %>
    <% unless proposal.supporting_groups.empty? %>
      <div class="flex flex-wrap items-center gap-1 mt-1">
        <% proposal.supporting_groups.each do |group| %>
          <span class="badge badge-secondary badge-sm font-bold"><%= group.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
