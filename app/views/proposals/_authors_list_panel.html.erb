<% if signed_in? && (@proposal.users.include? current_user) %>
  <% @proposal.users.each do |user| %>
    <%= user_tag(user, nil, true, false) %>
  <% end %>
  <% @proposal_presentation = @proposal.proposal_presentations.where(user_id: current_user.id).first %>
  <% if can? :destroy, @proposal_presentation %>
    <%= link_to t('.dont_want_to_be_an_author'), proposal_proposal_presentation_path(@proposal, @proposal_presentation), data: { turbo_method: :delete }, class: 'btn' %>
  <% end %>
<% else %>
  <% @proposal.users.each do |user| %>
    <%= user_tag(user, @proposal) %>
  <% end %>
<% end %>
<div style="clear: both;"></div>
