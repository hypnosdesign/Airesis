- j = 0
#promote_container.reveal-modal[data-reveal]
  h2
    = ''
  #promote_steps
    form#promote_form
      - if can? :vote, @proposal
        .legend

        .number
          = j+=1
        .title
          = 'Sign'
  .legend
    .number
      = j+=1
    .title
      = 'Suggestions'
  .legend
    .number
      = j+=1
    .title
      = 'Promote'
  .legend
    .number
      = j+=1
    .title
      = 'Share'
  .legend
    .number
      = j+=1
    .title
      = 'Facebook'
  .legend
    .number
      = j+=1
    .title
      = 'Become fan'
  .legend
    .number
      = j+=1
    .title
      = 'Twitter'
  .legend
    .number
      = j+=1
    .title
      = 'Donate'
  - if can? :vote, @proposal
    .step.root.root

    .panel.callout
      p
        = raw "Complimenti! La tua proposta è stata creata con successo!<br/>Inizia subito la raccolta firme!<br/>Tu sarai il primo firmatario della petizione. Aggiungi un commento e coinvolgi i tuoi amici per raccogliere altre firme e diffondere la petizione.<br/>Inserisci qui sotto il commento che verrà associato alla tua firma."
    textarea[style="width:60%;margin:auto;"]
    input.btn.blue[type="button" value="Firma e commenta"]
.step
  = t('proposals.promote.promote1_html')
.step
  = t('proposals.promote.promote2_html')
.step
  = t('proposals.promote.promote3_1_html')
  div[style="margin:auto;width:800px;"]
    = render 'banner'
  = t('proposals.promote.promote3_2_html')
  textarea[style="width:800px;height:120px;margin:auto;" onclick="this.select();"]
    |  <div id="airesis_p_
    = @proposal.id
    | ">
|  <script type="text/javascript" src="
= banner_proposal_url(@proposal)
| ">
.step
  = t('proposals.promote.promote4_html')
  |  <div class="fb-like" data-likeable_type="
  = @proposal.class.class_name
  | " data-likeable_id="
  = @proposal.id
  | " data-layout="standard" data-action="recommend" data-show-faces="true" data-share="false">
.step
  = t('proposals.promote.promote5_html')
  .fb-like[data-href="https://www.facebook.com/AiresisIt" data-layout="standard" data-action="recommend" data-show-faces="true" data-share="false"]
.step
  = t('proposals.promote.promote6_html')
  |  <a href="https://twitter.com/share" class="twitter-share-button" data-lang="en" data-count="vertical" data-text="Guarda questa proposta su #
  = APP_SHORT_NAME
  | ">Tweet
.step
  = t('proposals.promote.promote7_html')
  =render 'home/donate_buttons'
input.wizard[type="submit" style="visibility: hidden;"]
a.close-reveal-modal
  | ×