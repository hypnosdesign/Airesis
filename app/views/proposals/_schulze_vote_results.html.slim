div
  dl.tabs[data-tab]
    dd.active
      = link_to t('.results'), '#results'
    dd
      = link_to t('.votes'), '#votes'
  .tabs-content
    #results.content.active
      b
        = t('pages.proposals.results.total', count: @proposal.schulze_votes.sum(:count))
      table
        thead
          th
            = t('.solution')
          th
            = t('.points')
        tbody
          - solution_ids = @proposal.solutions.pluck(:id)
          - Solution.where(proposal_id: @proposal.id).order('schulze_score desc').each do |solution|
            tr
              td
                = raw t("pages.proposals.edit.new_solution_title.#{@proposal.proposal_type.name.downcase}", num: solution_ids.index(solution.id)+1)
                = solution.title.to_s
              td[style="text-align: center"]
                = solution.schulze_score
      hr
      table#votes_table
        thead
          th
            = t('pages.proposals.results.name_surname_column')
          th
            = t('pages.proposals.results.date_time_column')
          - unless @proposal.secret_vote
            th
              = t('pages.proposals.results.vote_column')
        - @proposal.user_votes.each do |user_vote|
          tr
            td
              = user_vote.user.fullname
            td
              = l user_vote.created_at
            - unless @proposal.secret_vote
              td
                = @proposal.is_schulze? ? user_vote.desc_vote_schulze : user_vote.vote_type.description
    #votes.content
      b
        = t('.random_ordered_votes')
      table#cast_table
        thead
          th
            = t('.number_of_voters')
          th
            = t('.vote')
        tbody
          - @proposal.schulze_votes.each do |vote|
            tr
              td
                = vote.count
              td
                = vote.description