<% if @group %>
  <%= link_to '#', class: "historyButton btn", onclick: "document.getElementById('regenerate_container').showModal(); return false;" do %>
    <i class="fa-solid fa-rotate-left"></i>
    <%= t('proposals.regenerate_button') %>
  <% end %>
<% else %>
  <%= link_to '#', class: "historyButton btn", onclick: "document.getElementById('regenerate_container').showModal(); return false;" do %>
    <i class="fa-solid fa-rotate-left"></i>
    <%= t('proposals.regenerate_button') %>
  <% end %>
<% end %>
<dialog id="regenerate_container" class="modal" data-controller="modal" data-modal-open-on-connect-value="false" data-modal-remove-on-close-value="false">
  <div class="modal-box">
    <h2 class="text-xl font-bold mb-4"><%= t('pages.proposals.show.new_quorum_title') %></h2>
    <%= simple_form_for @proposal, url: (@group ? regenerate_group_proposal_path(@group, @proposal) : regenerate_proposal_path(@proposal)) do |f| %>
      <%= render partial: '/proposal_types/quorum_choice', locals: { f: f } %>
      <div class="flex gap-2 mt-4">
        <%= link_to t('buttons.cancel'), '#', class: 'btn', data: { action: 'click->modal#close' } %>
        <%= f.submit t('pages.proposals.show.back_debate_button'), class: 'btn btn-primary', data: { disable_with: t('loading') } %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop" data-action="click->modal#backdropClose">
    <button>close</button>
  </form>
</dialog>
