<p class="inpoints">
  <span id="valutazioni" class="littleText"><%= t('pages.proposals.show.score') %></span>
  <span class="rightAlign"><%= @proposal.valutations %></span>
</p>
<p class="ranking">
  <span id="gradimento" class="littleText"><%= t('pages.proposals.show.rank') %></span>
  <span class="rightAlign"><%= @proposal.rank %>%</span>
</p>
<% mustache_proposal = proposal_for_mustache(@proposal) %>
<% if mustache_proposal['voting_or_voted?'] %>
  <%= render 'proposals/new_vote_bar', mustache_proposal %>
<% else %>
  <%= render 'proposals/new_rank_bar', mustache_proposal %>
<% end %>
