<% if current_user %>
  <% @unread = @proposal.contributes.listable.unread(current_user.id, @proposal.id) %>
<% end %>

<%= turbo_stream_from @proposal %>

<h1 class="proposalTitle text-2xl font-bold mb-4">
  <%= image_tag("proposal_types/#{@proposal.proposal_type.name.downcase}_ico.png", alt: @proposal.proposal_type.description, title: @proposal.proposal_type.description, style: "width:40px;padding-right:2px;vertical-align:middle") %>
  <span itemprop="name"><%= h @proposal.title %></span>
</h1>

<div class="flex flex-wrap gap-2 mb-4">
  <% if @proposal.contributes.count > 1 %>
    <% @removable_count = @proposal.contributes.unintegrated.removable.count %>
    <% @removed_count = @proposal.contributes.noise.count %>
    <% if ((is_proprietary? @proposal) || is_admin?) && (@removable_count + @removed_count > 0) %>
      <%= link_to t('pages.proposals.show.manage_noise_folder', removable: @removable_count, removed: @removed_count), manage_noise_proposal_proposal_comments_url(@proposal), class: 'btn btn-sm' %>
    <% elsif @proposal.contributes.noise.count > 0 %>
      <%= link_to t('pages.proposals.show.noise_folder'), noise_proposal_proposal_comments_url(@proposal), class: 'btn btn-sm' %>
    <% end %>
  <% end %>

  <% if @group %>
    <%= link_to edit_group_proposal_url(@group, @proposal), class: 'btn btn-sm' do %>
      <i class="fa-solid fa-pencil"></i> <%= t('pages.proposals.show.edit_button') %>
    <% end %>
    <%= link_to group_proposal_url(@group, @proposal), data: { turbo_method: :delete, turbo_confirm: t('pages.proposals.show.delete_proposal_confirmation') }, class: 'btn btn-sm btn-error btn-outline' do %>
      <i class="fa-regular fa-trash-can"></i> <%= t('pages.proposals.show.delete_button') %>
    <% end %>
  <% else %>
    <%= link_to edit_proposal_path(@proposal), class: 'btn btn-sm' do %>
      <i class="fa-solid fa-pencil"></i> <%= t('pages.proposals.show.edit_button') %>
    <% end %>
    <%= link_to @proposal, data: { turbo_method: :delete, turbo_confirm: t('pages.proposals.show.delete_proposal_confirmation') }, class: 'btn btn-sm btn-error btn-outline' do %>
      <i class="fa-regular fa-trash-can"></i> <%= t('pages.proposals.show.delete_button') %>
    <% end %>
  <% end %>

  <% if @proposal.in_valutation? %>
    <%= link_to @group ? close_debate_group_proposal_url(@group, @proposal) : close_debate_proposal_url(@proposal), data: { turbo_method: :post, turbo_confirm: t('pages.proposals.show.close_debate_proposal_confirmation') }, class: 'btn btn-sm btn-warning' do %>
      <i class="fa-solid fa-xmark"></i> <%= t('pages.proposals.show.close_debate_button') %>
    <% end %>
  <% elsif @proposal.waiting_date? %>
    <div id="wait_date_header_container">
      <%= render partial: 'proposals/wait_date_header' %>
    </div>
  <% elsif @proposal.voting? %>
    <% unless @proposal.is_petition? %>
      <b><%= raw t('.vote_here', link: (link_to t('buttons.vote_here'), '#', data: { scroll_to: :vote_panel })) %></b>
    <% end %>
  <% elsif @proposal.abandoned? %>
    <%= render partial: 'proposals/abandoned_header' %>
  <% elsif @proposal.voted? %>
    <div class="card hidden md:block"></div>
    <h2 id="status" class="text-xl font-bold"><%= @proposal.in_valutation? ? t('pages.proposals.show.during_debate') : @proposal.state.description %></h2>
    <%= link_to vote_results_proposal_url(@proposal), class: 'btn btn-sm results-button' do %>
      <%= t('pages.proposals.show.votation_results') %>
    <% end %>
  <% end %>
</div>

<dialog id="create_event_dialog" class="modal">
  <div class="modal-box"></div>
</dialog>

<div style="clear: both;"></div>

<% unless can? :participate, @proposal %>
  <% if @proposal.in_valutation? %>
    <div class="alert alert-info mb-4" data-alert>
      <% if signed_in? %>
        <% if @group.participants.include? current_user %>
          <%= t('pages.proposals.show.cant_participate.no_permissions') %>
          <%= link_to show_message_user_path(@group.portavoce.first) do %>
            <%= t('pages.proposals.show.cant_participate.ask_permissions') %>
          <% end %>
        <% elsif @group.requesting.include? current_user %>
          <%= t('pages.proposals.show.cant_participate.request_pending') %>
          <%= link_to show_message_user_path(@group.portavoce.first) do %>
            <%= t('pages.proposals.show.cant_participate.send_message') %>
          <% end %>
        <% else %>
          <%= t('pages.proposals.show.cant_participate.not_a_member') %>
          <%= link_to ask_for_participation_group_url(@group), data: { turbo_method: :post }, class: "btn btn-sm btn-primary" do %>
            <i class="fa-solid fa-pencil"></i> <%= t('pages.groups.show.ask_participate_button') %>
          <% end %>
        <% end %>
      <% else %>
        <%= t('pages.proposals.show.cant_participate.not_logged_in') %>
        <%= link_to t('pages.header.login').capitalize, '#', data: { login: '' } %>.
      <% end %>
    </div>
  <% end %>
<% end %>

<% unless @proposal.is_petition? %>
  <% if @proposal.waiting? %>
    <%= link_to @group ? start_votation_group_proposal_url(@group, @proposal) : start_votation_proposal_url(@proposal), data: { turbo_method: :post, turbo_confirm: t('pages.proposals.show.start_votation_proposal_confirmation') }, class: 'btn btn-primary mb-4' do %>
      <i class="fa-solid fa-check-square-o"></i> <%= t('pages.proposals.show.start_votation_button') %>
    <% end %>
    <div class="status_description card bg-base-200 p-4 mb-4">
      <b><%= t('pages.proposals.show.votation_message', from: l(@proposal.vote_period.starttime), to: l(@proposal.vote_period.endtime)) %></b>
    </div>
  <% elsif @proposal.in_valutation? %>
    <div class="status_description card bg-base-200 p-4 mb-4">
      <%= @proposal.quorum.explanation %>
    </div>
  <% elsif @proposal.abandoned? %>
    <div class="status_description card bg-base-200 p-4 mb-4">
      <%= "#{t('pages.proposals.show.abandoned_message', ago: time_ago_in_words(@proposal.updated_at))}: <b>#{l @proposal.updated_at}</b>".html_safe %>
    </div>
  <% end %>
<% end %>

<div class="card bg-base-100 p-6 mb-6">
  <% @proposal.sections.includes(:paragraphs).each do |section| %>
    <div class="proposal_main mb-6" data-section_id="<%= section.id %>">
      <div class="flex flex-wrap items-start gap-4">
        <div class="flex-1">
          <h3 class="text-lg font-semibold mb-2"><%= section.title %></h3>
        </div>
        <div class="w-auto">
          <% unless @proposal.voting? %>
            <% contributes_num = section.proposal_comments.listable.count %>
            <% unread = current_user ? section.proposal_comments.listable.unread(current_user.id, @proposal.id).count : contributes_num %>
            <div class="suggest">
              <a href="#" class="btn btn-sm btn-success contribute-button contribute-section-button" data-status="0" data-section_id="<%= section.id %>" data-contributes_num="<%= contributes_num %>" data-unread_contributes_num="<%= unread %>" title="<%= (can? :participate, @proposal) ? t('pages.proposals.show.give_contribute') : t('pages.proposals.show.read_contribute') %>">
                <i class="fa-solid fa-pencil"></i>
                <span class="contribute-button-text hidden md:inline"><%= (can? :participate, @proposal) ? t('pages.proposals.show.give_contribute') : t('pages.proposals.show.read_contribute') %></span>
                <span class="contribute-button-num">(<%= "#{unread}/#{contributes_num}" %>)</span>
              </a>
            </div>
          <% end %>
        </div>
      </div>
      <div class="proposal_content prose max-w-none">
        <%= parsed_section(section) %>
      </div>
    </div>
  <% end %>

  <% @proposal.solutions.includes(sections: :paragraphs).order('sections.seq').each_with_index do |solution, i| %>
    <div class="solution_main card bg-base-200 p-4 mb-4" data-solution_id="<%= solution.id %>">
      <h3 class="text-lg font-semibold mb-2">
        <%= raw t("pages.proposals.edit.new_solution_title.#{@proposal.proposal_type.name.downcase}", num: i+1) %>
        <%= solution.title %>
      </h3>
      <% solution.sections.each do |section| %>
        <div class="proposal_main mb-4" data-section_id="<%= section.id %>">
          <div class="flex flex-wrap items-start gap-4">
            <div class="flex-1">
              <h3 class="font-medium mb-2"><%= section.title %></h3>
            </div>
            <div class="w-auto">
              <% unless @proposal.voting? %>
                <% contributes_num = section.proposal_comments.listable.count %>
                <% unread = current_user ? section.proposal_comments.listable.unread(current_user.id, @proposal.id).count : contributes_num %>
                <div class="suggest">
                  <a href="#" class="btn btn-sm btn-success contribute-button contribute-section-button" data-status="0" data-section_id="<%= section.id %>" data-contributes_num="<%= contributes_num %>" data-unread_contributes_num="<%= unread %>" title="<%= (can? :participate, @proposal) ? t('pages.proposals.show.give_contribute') : t('pages.proposals.show.read_contribute') %>">
                    <i class="fa-solid fa-pencil"></i>
                    <span class="contribute-button-text hidden md:inline"><%= (can? :participate, @proposal) ? t('pages.proposals.show.give_contribute') : t('pages.proposals.show.read_contribute') %></span>
                    <span class="contribute-button-num">(<%= "#{unread}/#{contributes_num}" %>)</span>
                  </a>
                </div>
              <% end %>
            </div>
          </div>
          <div class="proposal_content prose max-w-none" data-id="<%= solution.id %>">
            <%= parsed_section(section) %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<div id="vote_panel_container">
  <%= render partial: 'vote_panel' %>
</div>
