<% comment_nickname = @proposal.proposal_nicknames.find_by_user_id(reply.user.id)
 %> <div id="replys
<%= ::Temple::Utils.escape_html((reply.id)) %>
"> <div class="reply_img" title=" 
<% if comment_nickname && @proposal.is_anonima?
 %><%= ::Temple::Utils.escape_html((comment_nickname.nickname)) %>
<% end %>"> 
<% if comment_nickname && @proposal.is_anonima?
 %> <img src="https://www.gravatar.com/avatar/
<%= ::Temple::Utils.escape_html((Digest::MD5.hexdigest(comment_nickname.nickname))) %>
?s=32&d=identicon&r=PG"/> 
<% else
 %><%= ::Temple::Utils.escape_html((avatar(reply.user, size: 32))) %>
<% end %><div class="proposal_comment_reply">
<div class="baloon-triangle">
</div><div class="reply_content">
<%= ::Temple::Utils.escape_html((parsed_content(reply, @proposal.is_anonima?))) %>
<div class="reply-footer" title="<%= ::Temple::Utils.escape_html((l(reply.created_at))) %>">
<% who = (comment_nickname && @proposal.is_anonima?) ? comment_nickname.nickname : reply.user.fullname
 %><%= ::Temple::Utils.escape_html((raw t('pages.proposals.show.comment_inserted_by', when: time_in_words(reply.created_at), who: who))) %>
</div></div><div style="clear: both;">
</div></div>
