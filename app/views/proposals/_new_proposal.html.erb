<% if @group %>
  <% if (!params[:group_area_id] && (can? :insert_proposal, @group)) || (params[:group_area_id] && (can? :insert_proposal, @group_area)) %>
    <%= link_to new_proposal_path(group_id: @group&.id, group_area_id: params[:group_area_id], category: params[:category], topic_id: @topic&.id, models: true), id: 'new_proposal_button', class: "create_proposal btn btn-primary disable" do %>
      <i class="fa-solid fa-plus"></i>
      <%= t('proposals.create_button') %>
    <% end %>
    <div class="choose_model" style="display:none;">
      <h2 class="modal_title"><%= t('pages.proposals.index.choose_model') %></h2>
      <div class="flex flex-wrap">
        <% ProposalType.active.for_groups.order(:seq).each do |proposal_type| %>
          <div class="w-full lg:w-3/12 md:w-6/12">
            <div class="proposal_model_option" data-url="<%= new_proposal_path(group_id: @group&.id, group_area_id: params[:group_area_id], category: params[:category], topic_id: @topic&.id, proposal_type_id: proposal_type.name, models: true) %>" style="background-color: <%= proposal_type.color %>">
              <div class="model_name">
                <div class="name"><%= proposal_type.description %></div>
              </div>
              <div class="icon">
                <%= image_tag("proposal_types/#{proposal_type.name.downcase}.png", align: 'middle', alt: proposal_type.description, title: proposal_type.description) %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <a class="close-reveal-modal">&times;</a>
    </div>
  <% end %>
<% else %>
  <%= link_to new_proposal_path(proposal_type_id: ProposalType::STANDARD, category: params[:category]), id: 'new_proposal_button', class: "btn btn-primary disable" do %>
    <i class="fa-solid fa-plus"></i>
    <%= t('proposals.create_button') %>
  <% end %>
<% end %>
