<h4><%= t('pages.proposals.vote_panel.single_title') %></h4>
<h4><%= @proposal.secret_vote ? t('pages.proposals.vote_panel.secret_vote') : t('pages.proposals.vote_panel.clear_vote') %></h4>
<%= form_with url: votation_vote_path(proposal_id: @proposal.id), method: :put do |f| %>
  <%= f.hidden_field 'vote_type' %>
  <% if current_user.rotp_enabled && ::Configuration.rotp %>
    <%= f.label 'Token di sicurezza' %>
    <br>
    <%= f.text_field 'token', maxlength: 6 %>
  <% end %>
  <ul class="flex gap-2">
    <li>
      <%= link_to t('pages.votations.show.vote_positive'), '#', class: "votegreen votebutton btn btn-success", title: t('pages.votations.show.vote_positive'), data: { vote_type: VoteType::POSITIVE } %>
    </li>
    <li>
      <%= link_to t('pages.votations.show.vote_neutral'), '#', class: "voteyellow votebutton btn btn-secondary", title: t('pages.votations.show.vote_neutral'), data: { vote_type: VoteType::NEUTRAL } %>
    </li>
    <li>
      <%= link_to t('pages.votations.show.vote_negative'), '#', class: "votered votebutton btn btn-error", title: t('pages.votations.show.vote_negative'), data: { vote_type: VoteType::NEGATIVE } %>
    </li>
  </ul>
<% end %>
<%= image_tag "spinner.gif", style: 'display: none;', class: "loading_vote" %>
<div style="clear: both"></div>
