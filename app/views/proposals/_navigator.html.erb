<div class="mybox">
<h4>
<%= ::Temple::Utils.escape_html((t('pages.proposals.edit.navigator'))) %>
 <i class="fa-solid fa-plus right" data-navigator-expand title="
<%= ::Temple::Utils.escape_html((t('proposals.edit.expand_all'))) %>
">
 <i class="fa-solid fa-minus right" data-navigator-collapse style="margin-right: 5px;" title="
<%= ::Temple::Utils.escape_html((t('proposals.edit.collapse_all'))) %>
">
</h4><div class="mycont">
<ul class="navigator navsections">
<% @proposal.sections.each_with_index do |section, i|
 %><%= ::Temple::Utils.escape_html((render 'section_navigator', mustache: {i: i, title: section.title})) %>
<% end %></ul><ul class="navigator navsolutions">
<% @proposal.solutions.each_with_index do |solution, i|
 %><%= ::Temple::Utils.escape_html((render 'solution_navigator', mustache: {i: i, title: (solution.title.present? ? solution.title : ' '), sections: solution.sections.map.with_index { |section, j| {i: (i + 1) * 100 + j, title: section.title, classes: 'sol'} })) %>
<% end %></ul></div></div>
