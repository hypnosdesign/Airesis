- proposal_nickname = @proposal.proposal_nicknames.find_by_user_id(comment.user.id)
|  <div id="comment
= comment.id
| " class="proposalComment"
= "style=\"display:none\" data-collapsed=\"true\"" if comment.collapsed
| > <div class="blogUserImage" title=" 
- if (proposal_nickname && @proposal.is_anonima?)
  = proposal_nickname.nickname
| "> 
- if (proposal_nickname && @proposal.is_anonima?)
  |  <img src="https://www.gravatar.com/avatar/
  = Digest::MD5.hexdigest(proposal_nickname.nickname)
  | ?s=40&d=identicon&r=PG"/> 
- else
  = avatar(comment.user, size: 40)
.proposal_comment
  .baloon-triangle

  div
    .baloon_header
      .right.report_contribute.hidden_link

      .report_menu.hidden_menu
        |  <div class="menu_item" data-report-contribute="
        = comment.id
        | "> 
        = t('buttons.report')
  .baloon-content
    = parsed_content(comment, @proposal.is_anonima?)
  .baloon-footer[title="#{l(comment.created_at)}"]
    - who = (proposal_nickname && @proposal.is_anonima?) ? proposal_nickname.nickname : (link_to_user comment.user, content_text: comment.user.fullname + ((proposal_nickname && @proposal.is_anonima?) ? (' (' + proposal_nickname.nickname + ')') : ''))
    = raw t('pages.proposals.show.comment_inserted_by', when: time_in_words(comment.created_at), who: who)
    = "in \"#{comment.paragraph.section.title}\"" if comment.paragraph
  |  <div id="rankingpanelcontainer
  = comment.id
  | " class="rankingpanelcontainer" style="display:none"> 
  = render partial: 'proposal_comments/ranking_panel_others', locals: {comment: comment}
div[style="clear:both;"]
|  <div id="
= comment.id
| _replies" style="display:none;"> 
|  <div id="
= comment.id
| _new_replies"> 
.reply_img[style="display:none"]

.proposal_comment_reply[style="display:none"]
  .baloon-triangle
  |  <div id="
  = comment.id
  | _reply_area_msg">
= form_for [@proposal, ProposalComment.new], remote: true do |f|
  .reply_area
    = f.hidden_field :parent_proposal_comment_id, value: comment.id
    = f.text_area :content, class: 'reply_textarea', data: {id: comment.id}, id: "#{comment.id}_reply_text_area", placeholder: t('pages.proposals.show.reply_placeholder')
  .reply_button
    = f.submit t('pages.proposals.show.reply_button'), class: 'btn disable', data: {disable_with: t('sending')}
  div[style="clear: both;"]