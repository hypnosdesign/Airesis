<div class="order-options">
<% if params[:state] == ProposalState::TAB_VOTATION.to_s
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_votation_end')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_date')) %>
<% elsif params[:state] == ProposalState::TAB_VOTED.to_s
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_votes_number')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_votation_end')) %>
<% elsif params[:state] == ProposalState::TAB_REVISION.to_s
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_date')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_rank')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_valutations')) %>
<% else
 %><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_date')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_rank')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_valutations')) %>
<span class="order_separator">
|
</span><%= ::Temple::Utils.escape_html((render partial: '/proposals/orders/order_by_debate_end')) %>
<% end %></div>
