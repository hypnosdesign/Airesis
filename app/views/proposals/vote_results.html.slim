- @page_title = t('pages.proposals.show.votation_results_title')
h1.proposalTitle[itemprop="name"]
  = h @proposal.title
= link_to t('pages.proposal_histories.index.back_to_proposal'), @group ? group_proposal_url(@group, @proposal) : proposal_url(@proposal), class: 'btn blue'
h2
  = @page_title
- if @proposal.voted?
  = render(partial: @proposal.is_schulze? ? 'schulze_vote_results' : 'vote_results')
- else
  h3
    ='This proposal has not been voted yet'
- content_for :left_panel do
  = render 'proposals/left_panel'