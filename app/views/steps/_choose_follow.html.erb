<div class="text">
  <b>
    <%= t('pages.steps.interest_borders.title') %>
    <br>
  </b>
  <%= t('pages.steps.choose_follow.description_html') %>
</div>
<ul id="groups_list" class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-4">
  <%= render partial: "/groups/group_tag", collection: current_user.suggested_groups, as: :group %>
</ul>
<%= form_for 'groupsi', url: {controller: 'groups', action: 'ask_for_multiple_follow'} do |f| %>
  <%= f.hidden_field 'group_ids' %>
  <%= f.button t('buttons.chosen'), class: 'btn btn-primary', style: "float:right;" %>
<% end %>
<div style="clear: both;"></div>
<br>
<script type="text/javascript">
  document.querySelectorAll('.groupListContainer').forEach(function(el) {
    el.addEventListener('click', function() {
      this.classList.toggle('highlighted');
      var ids = Array.from(document.querySelectorAll('.groupListContainer.highlighted')).map(function(e) { return e.dataset.id; }).join(';');
      var input = document.getElementById('groupsi_group_ids');
      if (input) input.value = ids;
      return false;
    });
  });
</script>
