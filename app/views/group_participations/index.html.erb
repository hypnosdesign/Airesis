<% @extend = true %>
<% javascript 'endless_page' %>
<h1><%= t('pages.groups.participations.list_participations') %></h1>
<% if can? :create, SearchParticipant %>
  <div class="flex flex-wrap w-full">
    <div class="flex flex-wrap">
      <div class="w-full lg:w-1/2">
        <div class="card bg-base-200 p-4">
          <h2><%= t('pages.groups.participations.search') %></h2>
          <%= simple_form_for [@group, @search_participant] do |f| %>
            <div class="flex flex-wrap">
              <div class="w-full lg:w-8/12">
                <%= f.input :keywords %>
              </div>
            </div>
            <div class="flex flex-wrap">
              <div class="w-full lg:w-8/12">
                <%= f.label :role_id %>
                <%= f.select :role_id, options_from_collection_for_select([OpenStruct.new({ id: ParticipationRole.admin.id, name: @group.admin_title || t('pages.groups.default_admin_title') })] + @group.participation_roles, :id, :name, (params[:search_participant][:role_id] if params[:search_participant])), include_blank: t('pages.groups.participations.anything') %>
              </div>
            </div>
            <div class="flex flex-wrap">
              <div class="w-full lg:w-8/12">
                <%= f.label :status_id %>
                <%= f.select :status_id, options_for_select(GroupParticipationRequest.group_participation_request_status_ids.except(:voting), params.dig(:search_participant, :status_id)), include_blank: t('pages.groups.participations.anything') %>
              </div>
            </div>
            <%= f.button :submit, t('pages.groups.participations.filter'), class: 'btn btn-primary', data: { disable_with: t('loading') } %>
          <% end %>
        </div>
      </div>
      <% if can? :update, @group %>
        <div class="w-full lg:w-1/2">
          <div class="card bg-base-200 p-4">
            <h2><%= t('pages.groups.participations.operations_on_user') %></h2>
            <%= link_to '#', class: 'btn invite-button', data: { 'reveal-id' => 'email_panel' } do %>
              <i class="fa-solid fa-envelope"></i>
              <%= t('pages.groups.participations.send_email') %>
            <% end %>
            <div id="email_panel" class="small">
              <h2><%= t('pages.users.send_message.massive_email') %></h2>
              <%= simple_form_for 'message', url: send_email_group_group_participations_path(@group), data: { turbo_method: :post } do |e| %>
                <%= e.input 'subject', label: t('pages.users.send_message.subject_label') %>
                <%= e.input 'body', as: :text, label: t('pages.users.send_message.body_label'), input_html: { rows: 10 } %>
                <%= e.hidden_field 'receiver_ids', value: @unscoped_group_participations.map { |p| p.user_id }.join(',') %>
                <a class="btn" href="#" onclick="document.getElementById('email_panel').close();return false;">
                  <%= t('buttons.cancel') %>
                </a>
                <%= e.submit t('buttons.send'), class: 'btn btn-primary', data: { disable_with: t('sending') } %>
              <% end %>
              <a class="close-">&times;</a>
            </div>
            <%= form_for 'destroy', url: destroy_all_group_group_participations_path(@group), data: { turbo_method: :post }, html: { style: 'display:inline;' } do |e| %>
              <%= e.hidden_field 'ids', value: @unscoped_group_participations.map { |p| p.id }.join(',') %>
              <%= link_to '#', class: 'btn', id: 'remove_all' do %>
                <i class="fa-regular fa-trash-can"></i>
                <%= t('pages.groups.participations.remove_all') %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
<div class="flex flex-wrap w-full">
  <ul id="results_container" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
    <%= render partial: 'group_participation_results' %>
  </ul>
</div>
<% if @group_participations.size > GroupParticipation::PER_PAGE %>
  <div id="loading_results" class="participant_results">
    <span><%= t('pages.blogs.show.more_participants') %></span>
  </div>
<% end %>
<% content_for :left_panel do %>
  <% if can? :update, @group %>
    <%= render partial: 'groups/administration_panel' %>
  <% end %>
  <div class="card bg-base-200 p-4">
    <%= link_to group_group_participations_url(@group, format: :csv), class: "btn" do %>
      <i class="fa-solid fa-print"></i>
      <%= t('pages.groups.show.print_all_participants') %>
    <% end %>
  </div>
<% end %>
<script type="text/javascript">
  var confirmation_message_1 = '<%= j raw t('pages.groups.edit_permissions.confirm_delete_1', count: @unscoped_group_participations.count) %>';
  var total_count = <%= @unscoped_group_participations.count %>;
  var csrf = document.querySelector('meta[name="csrf-token"]');
  var csrfToken = csrf ? csrf.content : '';

  document.addEventListener('focus', function(e) {
    if (e.target.matches('.user_role_changer')) {
      e.target.dataset.prevId = e.target.value;
      e.target.dataset.prevText = e.target.options[e.target.selectedIndex].text;
    }
  }, true);

  document.addEventListener('change', function(e) {
    if (!e.target.matches('.user_role_changer')) return;
    var select = e.target;
    var username = select.dataset.fullname;
    var gpId = select.dataset.id;
    var prevVal = select.dataset.prevId;
    var prevLabel = select.dataset.prevText;
    var curVal = select.value;
    var curLabel = select.options[select.selectedIndex].text;
    if (confirm('<%= j raw t('pages.groups.edit_permissions.confirm_role_change1') %> ' + username + ' <%= t('pages.groups.edit_permissions.confirm_role_change2') %> ' + prevLabel + ' <%= t('pages.groups.edit_permissions.confirm_role_change3') %> ' + curLabel + '. <%= t('pages.groups.edit_permissions.confirm_role_change4') %>')) {
      select.dataset.prevId = curVal;
      select.dataset.prevText = curLabel;
      fetch("/groups/<%= @group.id %>/group_participations/" + gpId + "/change_user_permission/", {
        method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrfToken, 'Accept': 'text/vnd.turbo-stream.html' },
        body: 'participation_role_id=' + curVal
      }).then(function(r) { return r.text(); }).then(function(html) { Turbo.renderStreamMessage(html); });
    } else { select.value = prevVal; }
  });

  var removeBtn = document.getElementById('remove_all');
  if (removeBtn) removeBtn.addEventListener('click', function(e) {
    e.preventDefault();
    if (confirm(confirmation_message_1)) { this.closest('form').submit(); }
  });

  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-change-area-participation]');
    if (!el) return;
    var gaId = el.dataset.group_area_id, uid = el.dataset.user_id;
    if (el.checked) {
      fetch("/groups/<%= @group.id %>/group_areas/" + gaId + "/area_participations", {
        method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrfToken, 'Accept': 'text/vnd.turbo-stream.html' },
        body: 'area_participation%5Buser_id%5D=' + uid
      }).then(function(r) { return r.text(); }).then(function(html) { Turbo.renderStreamMessage(html); });
    } else {
      fetch("/groups/<%= @group.id %>/group_areas/" + gaId + "/area_participations/-1", {
        method: 'DELETE', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrfToken, 'Accept': 'text/vnd.turbo-stream.html' },
        body: 'area_participation%5Buser_id%5D=' + uid
      }).then(function(r) { return r.text(); }).then(function(html) { Turbo.renderStreamMessage(html); });
    }
  });
</script>
