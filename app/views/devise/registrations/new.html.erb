<% @page_title = t('pages.registration.title') %>

<main class="flex-1 flex items-center justify-center px-4 py-12">
  <div class="flex w-full max-w-5xl bg-base-100 shadow-xl rounded-2xl overflow-hidden">

    <%# — Left: form — %>
    <div class="flex-1 p-8 sm:p-12 lg:p-16">
      <h1 class="text-3xl font-extrabold mb-2"><%= t('pages.registration.title', default: 'Crea il tuo account') %></h1>
      <p class="text-base-content/50 mb-8"><%= t('pages.registration.subtitle', default: 'Unisciti alla comunità e inizia a partecipare.') %></p>

      <%# Social buttons %>
      <% if ::Configuration.socialnetwork_active %>
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <%= link_to omniauth_authorize_path(:user, :google_oauth2),
              class: 'btn btn-outline flex-1 gap-3 font-semibold' do %>
            <svg class="w-5 h-5" viewBox="0 0 533.5 544.3">
              <path d="M533.5 278.4c0-18.5-1.5-37.1-4.7-55.3H272.1v104.8h147c-6.1 33.8-25.7 63.7-54.4 82.7v68h87.7c51.5-47.4 81.1-117.4 81.1-200.2z" fill="#4285f4"/>
              <path d="M272.1 544.3c73.4 0 135.3-24.1 180.4-65.7l-87.7-68c-24.4 16.6-55.9 26-92.6 26-71 0-131.2-47.9-152.8-112.3H28.9v70.1c46.2 91.9 140.3 149.9 243.2 149.9z" fill="#34a853"/>
              <path d="M119.3 324.3c-11.4-33.8-11.4-70.4 0-104.2V150H28.9c-38.6 76.9-38.6 167.5 0 244.4l90.4-70.1z" fill="#fbbc04"/>
              <path d="M272.1 107.7c38.8-.6 76.3 14 104.4 40.8l77.7-77.7C405 24.6 339.7-.8 272.1 0 169.2 0 75.1 58 28.9 150l90.4 70.1c21.5-64.5 81.8-112.4 152.8-112.4z" fill="#ea4335"/>
            </svg>
            Google
          <% end %>

          <%= link_to omniauth_authorize_path(:user, :facebook),
              class: 'btn btn-outline flex-1 gap-3 font-semibold' do %>
            <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor">
              <path d="M29 16c0-7.18-5.82-13-13-13S3 8.82 3 16c0 6.49 4.76 11.87 10.97 12.84V19.8h-3.3V16h3.3v-2.9c0-3.26 1.94-5.06 4.91-5.06 1.42 0 2.91.25 2.91.25v3.2h-1.64c-1.61 0-2.11 1-2.11 2.03V16h3.61l-.58 3.8h-3.03v9.04C24.24 27.87 29 22.49 29 16z" fill="#1877F2"/>
            </svg>
            Facebook
          <% end %>
        </div>

        <div class="divider text-sm text-base-content/40"><%= t('pages.registration.or_with_email', default: 'oppure con email') %></div>
      <% end %>

      <%# Validation errors %>
      <% if resource.errors.any? %>
        <div role="alert" class="alert alert-error mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
          <ul class="list-disc list-inside text-sm">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Form %>
      <%= form_with model: resource, url: registration_path(resource_name), data: { turbo: false }, class: 'space-y-4' do |f| %>
        <div class="flex flex-col sm:flex-row gap-4">
          <fieldset class="fieldset flex-1">
            <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.name') %></label>
            <%= f.text_field :name, required: true, placeholder: 'Mario',
                class: "input input-bordered w-full #{resource.errors[:name].any? ? 'input-error' : ''}" %>
            <% resource.errors[:name].each do |err| %>
              <p class="text-error text-xs mt-1"><%= err %></p>
            <% end %>
          </fieldset>
          <fieldset class="fieldset flex-1">
            <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.surname') %></label>
            <%= f.text_field :surname, placeholder: 'Rossi',
                class: "input input-bordered w-full #{resource.errors[:surname].any? ? 'input-error' : ''}" %>
            <% resource.errors[:surname].each do |err| %>
              <p class="text-error text-xs mt-1"><%= err %></p>
            <% end %>
          </fieldset>
        </div>

        <fieldset class="fieldset">
          <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.email') %></label>
          <%= f.email_field :email, required: true, autocomplete: 'email', placeholder: 'nome@esempio.it',
              class: "input input-bordered w-full #{resource.errors[:email].any? ? 'input-error' : ''}" %>
          <% resource.errors[:email].each do |err| %>
            <p class="text-error text-xs mt-1"><%= err %></p>
          <% end %>
        </fieldset>

        <fieldset class="fieldset">
          <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.password') %></label>
          <%= f.password_field :password, required: true, autocomplete: 'new-password', placeholder: t('pages.registration.min_chars', default: 'Minimo 6 caratteri'),
              class: "input input-bordered w-full #{resource.errors[:password].any? ? 'input-error' : ''}" %>
          <% resource.errors[:password].each do |err| %>
            <p class="text-error text-xs mt-1"><%= err %></p>
          <% end %>
        </fieldset>

        <fieldset class="fieldset">
          <label class="fieldset-label font-medium"><%= t('pages.registration.confirm_password') %></label>
          <%= f.password_field :password_confirmation, required: true, autocomplete: 'new-password', placeholder: t('pages.registration.repeat_password', default: 'Ripeti la password'),
              class: "input input-bordered w-full #{resource.errors[:password_confirmation].any? ? 'input-error' : ''}" %>
          <% resource.errors[:password_confirmation].each do |err| %>
            <p class="text-error text-xs mt-1"><%= err %></p>
          <% end %>
        </fieldset>

        <%# TOS checkbox %>
        <label class="label cursor-pointer gap-2 justify-start">
          <%= f.check_box :accept_conditions, class: "checkbox checkbox-sm checkbox-primary #{resource.errors[:accept_conditions].any? ? 'checkbox-error' : ''}" %>
          <span class="label-text text-sm">
            <%= t('pages.registration.i_accept', default: 'Accetto i') %>
            <button type="button" class="link link-primary" onclick="document.getElementById('reg_eula_modal').showModal()"><%= t('pages.registration.terms_link', default: 'Termini di Servizio') %></button>
            <%= t('words.and', default: 'e la') %>
            <button type="button" class="link link-primary" onclick="document.getElementById('reg_privacy_modal').showModal()"><%= t('pages.registration.privacy_link', default: 'Privacy Policy') %></button>
          </span>
        </label>
        <% resource.errors[:accept_conditions].each do |err| %>
          <p class="text-error text-xs"><%= err %></p>
        <% end %>
        <% resource.errors[:accept_privacy].each do |err| %>
          <p class="text-error text-xs"><%= err %></p>
        <% end %>

        <%# Hidden fields %>
        <%= f.hidden_field :sys_locale_id %>
        <%= f.hidden_field :accept_privacy, value: '0', id: 'user_accept_privacy_hidden' %>

        <% if ::Configuration.recaptcha %>
          <div><%= recaptcha_tags display: { 'theme' => 'clean' } %></div>
        <% end %>

        <button type="submit" class="btn btn-primary w-full font-bold text-base mt-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
            <circle cx="8.5" cy="7" r="4"/>
            <path d="M20 8v6M23 11h-6"/>
          </svg>
          <%= t('pages.registration.register_button') %>
        </button>
      <% end %>

      <p class="mt-6 text-center text-sm text-base-content/50">
        <%= t('pages.registration.already_have_account', default: 'Hai già un account?') %>
        <%= link_to t('pages.top_panel.login'), new_user_session_path, class: 'link link-primary font-semibold' %>
      </p>
    </div>

    <%# — Right: illustration — %>
    <div class="hidden lg:flex flex-1 bg-primary/10 items-center justify-center p-12">
      <div class="text-center">
        <svg class="w-48 h-48 mx-auto text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <h2 class="text-2xl font-bold text-primary mt-6"><%= t('pages.registration.join_us', default: 'Unisciti a noi') %></h2>
        <p class="text-base-content/50 mt-2 max-w-xs mx-auto"><%= t('pages.registration.join_desc', default: 'Oltre 20 lingue supportate. Decisioni trasparenti con il voto Schulze.') %></p>
        <div class="flex justify-center gap-4 mt-6">
          <div class="stat bg-base-100 rounded-xl p-4 shadow-sm">
            <div class="stat-value text-primary text-2xl">100%</div>
            <div class="stat-desc">Open Source</div>
          </div>
          <div class="stat bg-base-100 rounded-xl p-4 shadow-sm">
            <div class="stat-value text-primary text-2xl">20+</div>
            <div class="stat-desc"><%= t('pages.registration.languages', default: 'Lingue') %></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<%# — EULA Modal — %>
<dialog id="reg_eula_modal" class="modal">
  <div class="modal-box max-w-2xl max-h-[80vh]">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <h3 class="font-bold text-xl mb-4"><%= t('pages.registration.conditions_title', default: 'Termini di Servizio') %></h3>
    <div class="overflow-y-auto max-h-[60vh] text-sm leading-relaxed prose prose-sm">
      <%= render 'devise/registrations/eula' %>
    </div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-primary"><%= t('words.close', default: 'Chiudi') %></button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<%# — Privacy Modal — %>
<dialog id="reg_privacy_modal" class="modal">
  <div class="modal-box max-w-2xl max-h-[80vh]">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <h3 class="font-bold text-xl mb-4"><%= t('pages.registration.privacy_title', default: 'Privacy Policy') %></h3>
    <div class="overflow-y-auto max-h-[60vh] text-sm leading-relaxed prose prose-sm">
      <%= render 'devise/registrations/privacy' %>
    </div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-primary"><%= t('words.close', default: 'Chiudi') %></button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  // Sync: accettare TOS implica accettare anche privacy
  document.querySelector('[name="user[accept_conditions]"]').addEventListener('change', function() {
    document.getElementById('user_accept_privacy_hidden').value = this.checked ? '1' : '0';
  });
</script>
