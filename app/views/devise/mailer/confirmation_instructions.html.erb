<% host = @resource.original_locale.host
url_params = {confirmation_token: @token, host: host, protocol: DEFAULT_EMAIL_PROTOCOL}
url_params[:l] = @resource.original_locale.lang unless @resource.original_locale.lang.blank?
url = user_confirmation_url(url_params)
 %><p>
<%= ::Temple::Utils.escape_html((t('devise.mailer.confirmation_instructions.welcome', {app_name: APP_SHORT_NAME, user: @resource.fullname}))) %>
</p><p>
<%= ::Temple::Utils.escape_html((t('devise.mailer.confirmation_instructions.follow_link'))) %>
</p><p>
<%= ::Temple::Utils.escape_html((link_to t('devise.mailer.confirmation_instructions.confirm_account'), url)) %>
</p><p>
<%= ::Temple::Utils.escape_html((t('devise.mailer.confirmation_instructions.follow_link_2'))) %>
</p><p>
<%= ::Temple::Utils.escape_html((link_to url, url)) %>
</p><p>
<%= ::Temple::Utils.escape_html((t('devise.mailer.confirmation_instructions.access_by_email', {app_name: APP_SHORT_NAME}))) %>
</p><p>
<%= ::Temple::Utils.escape_html((t('devise.mailer.confirmation_instructions.contact_assistance', {mail: ENV['APP_EMAIL_ADDRESS']}))) %>
</p>
