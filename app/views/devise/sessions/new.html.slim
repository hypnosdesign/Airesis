- @page_title=t('pages.login.title')

.card.bg-base-100.shadow-lg.max-w-md.mx-auto.mt-8.p-8.rounded-2xl
  h2.text-2xl.font-bold.mb-6 = t('pages.login.title')

  - if ::Configuration.socialnetwork_active
    .flex.flex-col.gap-2.mb-6
      = link_to_ip t('pages.top_panel.facebook_login'), :facebook, 'facebook'
      = link_to_ip t('pages.top_panel.google_login'), :google_oauth2, 'google'
      = link_to_ip t('pages.top_panel.twitter_login'), :twitter, 'twitter'
    .divider

  = simple_form_for @user, url: user_session_path, html: { class: 'flex flex-col gap-4' } do |f|
    = f.input :email, required: true, input_html: { class: 'input input-bordered w-full' }
    = f.input :password, required: true, input_html: { class: 'input input-bordered w-full' }

    .form-control
      = f.label :remember_me, class: 'label cursor-pointer justify-start gap-2' do
        = f.check_box :remember_me, class: 'checkbox checkbox-primary'
        span.label-text = t('pages.sessions.new.remember_me_label')

    = button_tag type: :submit, class: 'btn btn-primary w-full' do
      i.fa-solid.fa-key.mr-2
      = t('buttons.login')

  .divider.mt-4

  = render 'devise/shared/links'
