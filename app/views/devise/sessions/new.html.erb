<% @page_title = t('pages.login.title') %>

<main class="flex-1 flex items-center justify-center px-4 py-12">
  <div class="flex w-full max-w-5xl bg-base-100 shadow-xl rounded-2xl overflow-hidden">

    <%# — Left: illustration — %>
    <div class="hidden lg:flex flex-1 bg-primary/10 items-center justify-center p-12">
      <div class="text-center">
        <svg class="w-48 h-48 mx-auto text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <h2 class="text-2xl font-bold text-primary mt-6"><%= t('pages.login.welcome_back', default: 'Bentornato!') %></h2>
        <p class="text-base-content/50 mt-2 max-w-xs mx-auto"><%= t('pages.login.welcome_desc', default: 'Accedi per partecipare alle decisioni della tua comunità.') %></p>
      </div>
    </div>

    <%# — Right: form — %>
    <div class="flex-1 p-8 sm:p-12 lg:p-16">
      <h1 class="text-3xl font-extrabold mb-2"><%= t('pages.login.title') %></h1>
      <p class="text-base-content/50 mb-8"><%= t('pages.login.subtitle', default: 'Inserisci le tue credenziali per continuare.') %></p>

      <%# Social buttons %>
      <% if ::Configuration.socialnetwork_active %>
        <div class="flex flex-col gap-3 mb-8">
          <%= link_to omniauth_authorize_path(:user, :google_oauth2),
              class: 'btn btn-outline w-full gap-3 font-semibold' do %>
            <svg class="w-5 h-5" viewBox="0 0 533.5 544.3">
              <path d="M533.5 278.4c0-18.5-1.5-37.1-4.7-55.3H272.1v104.8h147c-6.1 33.8-25.7 63.7-54.4 82.7v68h87.7c51.5-47.4 81.1-117.4 81.1-200.2z" fill="#4285f4"/>
              <path d="M272.1 544.3c73.4 0 135.3-24.1 180.4-65.7l-87.7-68c-24.4 16.6-55.9 26-92.6 26-71 0-131.2-47.9-152.8-112.3H28.9v70.1c46.2 91.9 140.3 149.9 243.2 149.9z" fill="#34a853"/>
              <path d="M119.3 324.3c-11.4-33.8-11.4-70.4 0-104.2V150H28.9c-38.6 76.9-38.6 167.5 0 244.4l90.4-70.1z" fill="#fbbc04"/>
              <path d="M272.1 107.7c38.8-.6 76.3 14 104.4 40.8l77.7-77.7C405 24.6 339.7-.8 272.1 0 169.2 0 75.1 58 28.9 150l90.4 70.1c21.5-64.5 81.8-112.4 152.8-112.4z" fill="#ea4335"/>
            </svg>
            <%= t('pages.top_panel.google_login', default: 'Accedi con Google') %>
          <% end %>

          <%= link_to omniauth_authorize_path(:user, :facebook),
              class: 'btn btn-outline w-full gap-3 font-semibold' do %>
            <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor">
              <path d="M29 16c0-7.18-5.82-13-13-13S3 8.82 3 16c0 6.49 4.76 11.87 10.97 12.84V19.8h-3.3V16h3.3v-2.9c0-3.26 1.94-5.06 4.91-5.06 1.42 0 2.91.25 2.91.25v3.2h-1.64c-1.61 0-2.11 1-2.11 2.03V16h3.61l-.58 3.8h-3.03v9.04C24.24 27.87 29 22.49 29 16z" fill="#1877F2"/>
            </svg>
            <%= t('pages.top_panel.facebook_login', default: 'Accedi con Facebook') %>
          <% end %>
        </div>

        <div class="divider text-sm text-base-content/40"><%= t('pages.login.or_with_email', default: 'oppure con email') %></div>
      <% end %>

      <%# Form %>
      <%= simple_form_for @user, url: user_session_path, html: { class: 'space-y-4' }, data: { turbo: false } do |f| %>
        <fieldset class="fieldset">
          <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.email') %></label>
          <%= f.input_field :email, required: true, placeholder: 'nome@esempio.it',
              class: 'input input-bordered w-full' %>
        </fieldset>

        <fieldset class="fieldset">
          <label class="fieldset-label font-medium"><%= t('activerecord.attributes.user.password') %></label>
          <%= f.input_field :password, as: :password, required: true, placeholder: t('pages.login.your_password', default: 'La tua password'),
              class: 'input input-bordered w-full' %>
        </fieldset>

        <div class="flex items-center justify-between">
          <label class="label cursor-pointer gap-2">
            <%= f.check_box :remember_me, class: 'checkbox checkbox-sm checkbox-primary' %>
            <span class="label-text text-sm"><%= t('pages.sessions.new.remember_me_label') %></span>
          </label>
          <%= link_to t('pages.sessions.links.forgot_password'), new_password_path(resource_name),
              class: 'link link-primary text-sm font-medium' %>
        </div>

        <button type="submit" class="btn btn-primary w-full font-bold text-base mt-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          <%= t('buttons.login') %>
        </button>
      <% end %>

      <p class="mt-6 text-center text-sm text-base-content/50">
        <%= t('pages.login.no_account', default: 'Non hai un account?') %>
        <%= link_to t('pages.sessions.links.register'), new_registration_path(resource_name),
            class: 'link link-primary font-semibold' %>
      </p>
    </div>

  </div>
</main>
