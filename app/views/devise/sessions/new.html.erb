<% @page_title = t('pages.login.title') %>

<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center py-8 px-4">
  <div class="w-full max-w-4xl bg-base-100 border-2 border-base-content shadow-brutal flex flex-col lg:flex-row overflow-hidden">

    <%# — Left: form — %>
    <div class="lg:w-1/2 p-8 sm:p-12 flex flex-col justify-center">

      <h1 class="text-3xl font-extrabold mb-8"><%= t('pages.login.title') %></h1>

      <%# Social login %>
      <% if ::Configuration.socialnetwork_active %>
        <div class="flex flex-col gap-3">
          <%= link_to omniauth_authorize_path(:user, :google_oauth2),
              class: 'btn btn-outline border-2 gap-3 w-full justify-center font-semibold' do %>
            <svg class="w-5 h-5" viewBox="0 0 533.5 544.3">
              <path d="M533.5 278.4c0-18.5-1.5-37.1-4.7-55.3H272.1v104.8h147c-6.1 33.8-25.7 63.7-54.4 82.7v68h87.7c51.5-47.4 81.1-117.4 81.1-200.2z" fill="#4285f4"/>
              <path d="M272.1 544.3c73.4 0 135.3-24.1 180.4-65.7l-87.7-68c-24.4 16.6-55.9 26-92.6 26-71 0-131.2-47.9-152.8-112.3H28.9v70.1c46.2 91.9 140.3 149.9 243.2 149.9z" fill="#34a853"/>
              <path d="M119.3 324.3c-11.4-33.8-11.4-70.4 0-104.2V150H28.9c-38.6 76.9-38.6 167.5 0 244.4l90.4-70.1z" fill="#fbbc04"/>
              <path d="M272.1 107.7c38.8-.6 76.3 14 104.4 40.8l77.7-77.7C405 24.6 339.7-.8 272.1 0 169.2 0 75.1 58 28.9 150l90.4 70.1c21.5-64.5 81.8-112.4 152.8-112.4z" fill="#ea4335"/>
            </svg>
            <%= t('pages.top_panel.google_login') %>
          <% end %>

          <%= link_to omniauth_authorize_path(:user, :facebook),
              class: 'btn btn-outline border-2 gap-3 w-full justify-center font-semibold' do %>
            <i class="fa-brands fa-facebook text-lg text-[#1877F2]"></i>
            <%= t('pages.top_panel.facebook_login') %>
          <% end %>

          <%= link_to omniauth_authorize_path(:user, :twitter),
              class: 'btn btn-outline border-2 gap-3 w-full justify-center font-semibold' do %>
            <i class="fa-brands fa-twitter text-lg text-[#1DA1F2]"></i>
            <%= t('pages.top_panel.twitter_login') %>
          <% end %>
        </div>

        <div class="divider text-sm font-medium my-6"><%= t('words.or') %></div>
      <% end %>

      <%= simple_form_for @user, url: user_session_path, html: { class: 'flex flex-col gap-4' }, data: { turbo: false } do |f| %>

        <div class="form-control">
          <%= f.label :email, class: 'label font-semibold text-sm' %>
          <%= f.input_field :email, required: true, placeholder: 'name@example.com',
              class: 'input input-bordered w-full' %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: 'label font-semibold text-sm' %>
          <%= f.input_field :password, required: true, as: :password,
              class: 'input input-bordered w-full' %>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :remember_me, class: 'checkbox checkbox-primary checkbox-sm' %>
            <span class="text-sm"><%= t('pages.sessions.new.remember_me_label') %></span>
          </label>
          <%= link_to t('pages.sessions.links.forgot_password'), new_password_path(resource_name),
              class: 'link link-primary text-sm' %>
        </div>

        <%= button_tag type: :submit, class: 'btn btn-primary w-full text-base font-semibold mt-2' do %>
          <i class="fa-solid fa-right-to-bracket mr-2"></i>
          <%= t('buttons.login') %>
        <% end %>
      <% end %>

      <div class="divider my-6"></div>

      <p class="text-center text-sm text-base-content/70">
        <%= t('pages.login.no_account', default: 'Non hai un account?') %>
        <%= link_to t('pages.sessions.links.register'), new_registration_path(resource_name),
            class: 'link link-primary font-semibold' %>
      </p>

      <p class="text-center text-sm text-base-content/50 mt-2">
        <%= link_to t('pages.sessions.links.havent_received_email'), new_confirmation_path(resource_name),
            class: 'link link-hover' %>
      </p>
    </div>

    <%# — Right: illustration — %>
    <div class="hidden lg:flex lg:w-1/2 bg-primary/10 items-center justify-center p-12">
      <div class="text-center">
        <svg class="w-64 h-64 mx-auto text-primary opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          <circle cx="12" cy="16" r="1"/>
        </svg>
        <h2 class="text-2xl font-bold mt-6 text-base-content"><%= APP_SHORT_NAME %></h2>
        <p class="text-base-content/60 mt-2 max-w-xs mx-auto"><%= t('pages.landing.payoff', default: 'La piattaforma per la democrazia partecipativa') %></p>
      </div>
    </div>
  </div>
</div>
