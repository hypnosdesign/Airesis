- if @group ? (can? :create_event, @group) : is_admin?
  style[type="text/css"]
    |  .fc-widget-content { cursor: pointer; } .fc-widget-content:hover { background-color: #f5f8f9; } .fc-widget-content:active { background-color: #fbec88; } 
.calendar_container.card
  #calendar

#create_event_dialog.reveal-modal.medium[data-reveal]

.choose_event_type[style="display:none;"]
  h2.modal_title
    = t('pages.events.index.choose_type')
  div[style="max-width:540px;margin:auto;"]
    - EventType.active.each do |event_type|
      |  <div class="event_model_option" data-id="
      = event_type.id
      | " style="background-color: 
      = event_type.color
      | "> 
      .model_name

      .name
        = event_type.description.upcase
      .icon
        = image_tag "event_types/#{event_type.name.downcase}.png", align: 'middle', alt: event_type.description, title: event_type.description, style: 'width:160px'
a.close-reveal-modal
  | ×
= content_for :left_panel do
  - if @group
    .mybox
      - if can? :create_any_event, @group
        = link_to '#', class: 'btn blue create_event' do
          i.fa-solid.fa-plus
          = t('pages.calendar.create_event_button')
      - elsif can? :create_event, @group
        = link_to new_group_event_url(@group, event_type_id: EventType::MEETING), remote: true, class: 'btn blue', data: {disable_with: t('loading')} do
          i.fa-solid.fa-plus
          = t('pages.calendar.create_event_button')
      - elsif can? :create_date, @group
        = link_to new_group_event_url(@group, event_type_id: EventType::VOTATION), remote: true, class: 'btn blue', data: {disable_with: t('loading')} do
          i.fa-solid.fa-plus
          = t('pages.calendar.create_event_button')
      = link_to '<img src="//www.google.com/calendar/images/ext/gc_button6.gif" border=0>'.html_safe, "http://www.google.com/calendar/render?cid=#{group_events_url(@group, format: :ics)}", target: '_blank', style: 'display: table; margin: 25px auto;'
  - else
    - if is_admin?
      .mybox
        = link_to '#', class: 'btn blue disable create_event' do
          i.fa-solid.fa-plus
          = t('pages.calendar.create_event_button')
script[type="text/javascript"]
  |  EventsIndex.newEventUrl = '#{j raw new_event_url(group_id: @group.try(:id), models: true)}'; EventsIndex.newEventUrlClick = '#{j raw new_event_url(group_id: @group.try(:id))}'; EventsIndex.eventsUrl = '#{@group ? group_events_url(@group) : events_url}'; EventsIndex.autoOpen = #{params[:new_event] == 'true'}; EventsIndex.autoOpenUrl = '#{j raw new_event_url(group_id: @group.try(:id), event_type_id: params[:event_type_id])}'; EventsIndex.loadingFragment = '#{j render("fragments/loading")}'; EventsIndex.defaultEventType = #{EventType::MEETING}; EventsIndex.calendarI18n = { firstDay: #{t('calendar.firstDay')}, monthNames: #{raw t('calendar.monthNames')}, monthNamesShort: #{raw t('calendar.monthNamesShort')}, dayNames: #{raw t('calendar.dayNames')}, dayNamesShort: #{raw t('calendar.dayNamesShort')}, timeFormat: '#{raw t('calendar.eventsFormat')}', buttonText: { prevYear: "<span class='fc-text-arrow'>«</span>", nextYear: "<span class='fc-text-arrow'>»</span>", today: '#{t('calendar.today')}', month: '#{t('calendar.month')}', week: '#{t('calendar.week')}', day: '#{t('calendar.day')}' } }; EventsIndex.createEvent = #{@group ? (can? :create_event, @group) : is_admin?}; 