<%# FullCalendar v6 — Cleopatra reference: docs/dashboard_template/src/pages/apps/calendar.html %>
<%
  events_url  = @group ? group_events_url(@group, format: :json) : events_url(format: :json)
  editable    = @group ? (can?(:create_event, @group) || can?(:create_any_event, @group)) : is_admin?
  new_evt_url = if @group
                  if can?(:create_any_event, @group) || can?(:create_event, @group)
                    new_group_event_url(@group, event_type_id: EventType::MEETING)
                  elsif can?(:create_date, @group)
                    new_group_event_url(@group, event_type_id: EventType::VOTATION)
                  end
                elsif current_user
                  # Passa l'URL a tutti gli utenti loggati: la form gestisce l'autorizzazione
                  new_event_url
                end
%>

<div class="bg-base-100 border-2 border-base-content/15">
  <div id="fc-calendar"
       data-controller="calendar"
       data-calendar-events-url-value="<%= events_url %>"
       data-calendar-new-event-url-value="<%= new_evt_url || '' %>"
       data-calendar-locale-value="<%= I18n.locale %>"
       data-calendar-editable-value="<%= editable %>">
  </div>
</div>

