- if can? :update, @event
  .mybox
    = link_to (@group ? edit_group_event_path(@group, @event) : edit_event_path(@event)),
              remote: true, class: 'btn', data: {disable_with: t('loading')} do
      i.fa-solid.fa-pencil
      = t('buttons.edit')
- if can? :destroy, @event
  = link_to @event, method: :delete, class: 'btn red',
            data: {confirm: t('delete_event_confirm'), disable_with: t('loading')} do
    i.fa-regular.fa-trash-can
    = t('buttons.delete')
- if ::Configuration::socialnetwork_active
  .mybox
    |  <a href="https://twitter.com/share" class="twitter-share-button" data-lang="en" data-count="vertical" data-text="
    = t('twitter.share.event', app: APP_SHORT_NAME)
    | ">Tweet
    g:plusone[size="tall"]
    |  <div class="fb-like" data-send="false" data-layout="box_count" data-width="100" data-show-faces="false" data-likeable_type="
    = @event.class.class_name
    | " data-likeable_id="
    = @event.id
    | ">
- if @event.meeting
  .mybox.participation_panel_container
    = render partial: 'participation_panel'
  - if @event.meeting
    .participants_container
      = render partial: 'meeting_responses'