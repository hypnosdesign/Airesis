<div id="post_<%= ::Temple::Utils.escape_html((post_counter + 1)) %>">.row.full-width.post-container[data-equalizer]

.columns.small-2.user_post.text-center[data-equalizer-watch]

  a[name="post-<%= ::Temple::Utils.escape_html((post.id)) %>"]

  |  <div class='post 

  = cycle('odd', 'even')

  |  span10'> 

  - if post.pending_review?

    .moderation.alert

      = t(".pending_review")

      - if forem_admin_or_moderator?(post.topic.forum)

        - if local_assigns[:mass_moderation]

          = render "/frm/posts/moderation_tools", post: post

        - else

          = form_tag group_frm_forum_moderate_posts_url(@group, forum), method: :put do

            = render "/frm/posts/moderation_tools", post: post

.user.span2

  .icon

    = avatar(post.user, size: 100) if post.user

  .username

    = link_to(post.user.fullname, post.user) if post.user</div>
<div class="columns small-10 non_user_post" data-equalizer-watch="">
<div class="row post-header">
<div class="columns">
<a href="#post-<%= ::Temple::Utils.escape_html((post.id)) %>">
<div class="post-when">
 <time datetime="
<%= ::Temple::Utils.escape_html((post.created_at.to_s(:db))) %>
">
<%= ::Temple::Utils.escape_html(("#{time_ago_in_words(post.created_at)}")) %>
<% if post.reply_to
 %><span class="in-reply-to">
<%= ::Temple::Utils.escape_html((link_to "#{t(".in_reply_to")} #{post.reply_to.user}", "#post-#{post.reply_to.id}")) %>
</span><% end %></div><% if current_user
 %><div class="btn-group">
<% if can?(:reply, post.topic)
if post.topic.can_be_replied_to?
 %><%= ::Temple::Utils.escape_html((link_to t('reply', scope: 'frm.topic'), new_group_forum_topic_post_url(@group, post.topic.forum, post.topic, reply_to_id: post.id))) %>
<%= ::Temple::Utils.escape_html((link_to t('quote', scope: 'frm.topic'), new_group_forum_topic_post_url(@group, post.topic.forum, post.topic, reply_to_id: post.id, quote: true))) %>
<% end; end; if post.owner_or_moderator?(current_user)
if can?(:edit_post, post.topic.forum)
 %><%= ::Temple::Utils.escape_html((link_to t('edit', scope: 'frm.post.buttons'), edit_group_forum_topic_post_url(@group, post.topic.forum, post.topic, post))) %>
<% end %><%= ::Temple::Utils.escape_html((link_to t('delete', scope: 'frm.topic'), group_forum_topic_post_url(@group, post.topic.forum, post.topic, post), method: :delete, data: {confirm: t("are_you_sure")})) %>
<% end %></div><% end %></a></div></div><div class="row">
<div class="columns post_content">
<div class="post-body">
<%= ::Temple::Utils.escape_html((sanitize post.text)) %>
</div></div></div></div>
