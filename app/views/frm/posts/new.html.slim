= render partial: 'frm/forums/head', locals: { forum: @topic.forum }
- if @reply_to_post
  h2
    = t("frm.post.new")
  .row
    = render 'reply_to_post', post: @reply_to_post
- else
  h3.topic_subject
    = @topic.subject
= simple_form_for @post, url: group_forum_topic_posts_url(@group,@topic.forum, @topic) do |f|
  = render partial: "form", locals: { f: f }
  = f.submit t("frm.post.buttons.reply"), class: "btn blue"