<%= render partial: 'frm/forums/head', locals: { forum: @topic.forum } %>

<h2 class="text-xl font-bold mb-4"><%= t('frm.post.edit') %></h2>

<%= simple_form_for @post, url: group_forum_topic_post_url(@group, @topic.forum, @topic, @post) do |f| %>
  <%= render partial: 'form', locals: { f: f } %>
  <%= f.submit t("frm.post.buttons.edit"), class: 'btn btn-primary mt-4' %>
<% end %>
