- @page_title = "#{@category} - #{@group.name}"
- @extend=true
ul.breadcrumbs
  li
    = link_to t('frm.forum.forums'), group_forums_url(@group)
  li.current
    = link_to @category, group_frm_category_url(@group, @category)
.category
  = render @category
= content_for :left_panel do
  = render partial: 'groups/administration_panel'
= render partial: '/frm/application/forem_footer'