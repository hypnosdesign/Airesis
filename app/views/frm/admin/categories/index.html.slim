ul.breadcrumbs
  li
    = link_to t('pages.groups.administration_panel.forum'), group_frm_admin_root_url(@group)
  li.current
    = t("frm.admin.category.index")
table#forums.forums.table-striped.table[cellspacing="0"]
  thead
    tr
      th
        = t('category', scope: 'frm.admin.categories')
      th
        = t('edit', scope: 'frm.admin.categories')
      th
        = t('delete', scope: 'frm.admin.categories')
  tbody
    = render partial: 'categories'
= link_to t("frm.admin.category.new_link"), new_group_frm_admin_category_url(@group), class: "btn blue", remote: true, data:{disable_with: t('loading')}
br
= content_for :left_panel do
  = render partial: 'groups/administration_panel'