<h2 class="text-xl font-bold mb-4"><%= t('frm.admin.category.edit', title: @category.name) %></h2>

<%= simple_form_for @category, url: group_frm_admin_category_url(@group, @category) do |f| %>
  <%= f.input :name %>
  <%= f.input :tags_list %>
  <%= f.input :visible_outside %>
  <div class="flex gap-2 mt-4">
    <%= link_to t('buttons.cancel'), '#', class: 'btn', data: { action: "click->modal#close" } %>
    <%= f.submit class: "btn btn-primary", data: { disable_with: t('loading') } %>
  </div>
<% end %>
