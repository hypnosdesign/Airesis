<div class="breadcrumbs text-sm mb-4">
  <ul>
    <li><%= link_to t('pages.groups.administration_panel.forum'), group_frm_admin_root_url(@group) %></li>
    <li><%= link_to t('frm.admin.group.index'), group_frm_admin_mods_url(@group) %></li>
    <li><%= @frm_mod.name %></li>
  </ul>
</div>

<div class="card bg-base-200 p-4 mb-4">
  <div class="add-member-form">
    <%= render 'frm/admin/mods/add_form' %>
  </div>
</div>

<div class="card bg-base-200 p-4">
  <div id="group_members_container">
    <%= render 'group_members' %>
  </div>
</div>

<script type="text/javascript">
  ModsShow.autocompleteUrl = '<%= j group_user_autocomplete_url(@group) %>';
</script>

<% content_for :left_panel do %>
  <%= render 'groups/administration_panel' %>
<% end %>
