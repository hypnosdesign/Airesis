<h2 class="text-xl font-bold mb-4"><%= @page_title %></h2>

<%= simple_form_for @frm_mod, url: group_frm_admin_mods_url(@group), remote: remote do |f| %>
  <%= f.input :name %>
  <div class="flex gap-2 mt-4">
    <%= link_to t('buttons.cancel'), '#', class: 'btn', data: { 'reveal-close' => '' } %>
    <%= link_to t('buttons.go_back'), :back, class: 'btn', data: { back: '' } %>
    <%= f.submit class: "btn btn-primary", data: { disable_with: t('loading') } %>
  </div>
<% end %>
