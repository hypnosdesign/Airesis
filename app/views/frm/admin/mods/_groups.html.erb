<div id="groups_table">
<% if @frm_mods.empty? %>
  <h4 class="text-lg"><%= t('pages.forum_groups.index.create_first') %></h4>
<% else %>
  <table class="table index table-striped" cellspacing="0">
    <thead>
      <tr>
        <th><%= t('name', scope: 'frm.admin.mods') %></th>
        <th><%= t('edit', scope: 'frm.admin.mods') %></th>
        <th><%= t('delete', scope: 'frm.admin.mods') %></th>
      </tr>
    </thead>
    <tbody>
      <% @frm_mods.each do |group| %>
        <tr>
          <td>
            <%= link_to group.name, group_frm_admin_mod_url(@group, group) %>
            <br>
            <% group.members.each do |member| %>
              <%= avatar(member, size: 20) %>
            <% end %>
          </td>
          <td>
            <%= link_to group_frm_admin_mod_url(@group, group), class: 'btn btn-sm' do %>
              <i class="fa-solid fa-pencil"></i>
              <%= t('edit', scope: 'frm.admin.mods') %>
            <% end %>
          </td>
          <td>
            <%= link_to group_frm_admin_mod_url(@group, group), method: :delete, data: { confirm: t('confirm_delete') }, class: 'btn btn-sm btn-error' do %>
              <i class="fa-regular fa-trash-can"></i>
              <%= t('delete', scope: 'frm.admin.mods') %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
</div>
