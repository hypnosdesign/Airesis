table#forums.forums.table.table-striped[cellspacing="0"]
  thead
    tr
      th.desc
        = t('forum', scope: 'frm.general')
      th.topics-count
        = t('topics', scope: 'frm.general')
      th.posts-count
        = t('posts', scope: 'frm.general')
      th.views-count
        = t('frm.forums.index.views')
      th.last-post
        = t('last_post')
  tbody
    = render category.forums