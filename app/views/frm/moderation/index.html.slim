h2
  = t('.title', forum: forum)
h3
  = t('posts_count', count: @posts.count, scope: 'frm.general')
= form_tag group_frm_forum_moderate_posts_url(@group,forum), method: :put do
  #posts
    - @posts.limit(25).group_by(&:topic).each do |topic, posts|
      h4
        = topic.forum.title
        |  » 
        = topic.subject
      = render posts, mass_moderation: true
  = submit_tag t('frm.posts.moderation.moderate'), class: "btn btn-primary"