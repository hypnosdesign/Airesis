<% if !@topic.subscriber?(current_user.id) %>
  <%= link_to subscribe_group_forum_topic_url(@group, @forum, @topic), remote: true, class: "btn btn-sm" do %>
    <i class="fa-solid fa-bell"></i>
    <%= t("frm.topics.show.subscribe") %>
  <% end %>
<% else %>
  <%= link_to unsubscribe_group_forum_topic_url(@group, @forum, @topic), remote: true, class: "btn btn-sm" do %>
    <i class="fa-solid fa-bell-slash"></i>
    <%= t("frm.topics.show.unsubscribe") %>
  <% end %>
<% end %>
