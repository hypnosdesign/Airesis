<div class="topic <%= cycle('odd', 'even') %> <%= topic.locked? ? 'locked' : 'unlocked' %>">
  <div class="<%= icon_classes(topic) %>"></div>
  <div class="byline topic-title">
    <%= new_since_last_view_text(topic) %>
    <div class="subject">
      <%= link_to topic.subject, group_forum_topic_url(topic.forum.group, topic.forum, topic) %>
    </div>
    <div class="started-by text-sm text-base-content/60">
      <%= t('started_by') %> <%= relevant_posts(topic).first.user %>
    </div>
  </div>
</div>
