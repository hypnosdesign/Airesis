<% blog_post = post_publishing.blog_post %>
<div class="card blogPost bg-base-200 p-4 mb-4" id="blogPost<%= blog_post.id %>">
  <% if (can? :remove_post, @group) || (can? :update, blog_post) %>
    <div class="dropdown dropdown-end float-right">
      <button tabindex="0" class="btn btn-ghost btn-xs"><i class="fa-solid fa-ellipsis-vertical"></i></button>
      <ul tabindex="0" class="dropdown-content menu bg-base-300 rounded-box shadow-lg z-10 p-2 w-40">
        <% if can? :remove_post, @group %>
          <li><%= link_to t("pages.groups.show.featured_post.#{post_publishing.featured}"), feature_post_group_path(@group, post_id: blog_post.id), data: { turbo_method: :put }, class: 'menu_item' %></li>
        <% end %>
        <li><%= link_to t('pages.groups.show.remove_post'), remove_post_group_path(@group, post_id: blog_post.id), data: { turbo_method: :put, turbo_confirm: "Sei sicuro di voler rimuovere il post '#{blog_post.title}' dalla bacheca del gruppo?" }, class: 'menu_item' %></li>
        <% if can? :update, blog_post %>
          <li><%= link_to t('pages.blog_posts.edit_button'), edit_blog_blog_post_path(blog_post.blog, blog_post), class: 'menu_item' %></li>
          <li><%= link_to t('pages.blog_posts.delete_button'), blog_blog_post_path(blog_post.blog, blog_post), data: { turbo_method: :delete, turbo_confirm: "Sei sicuro di voler cancellare il post '#{blog_post.title}'. Esso scomparirà sia dall bacheca del gruppo che dal tuo blog personale e non sarà più possibile recuperarlo." }, class: 'menu_item' %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h3 class="blogPostTitle text-lg font-bold mb-2">
    <%= blog_post_label blog_post %>
    <%= link_to blog_post.title, group_blog_post_url(@group, blog_post) %>
  </h3>

  <div class="blogPostBody mb-4">
    <%= truncate(blog_post.body.to_plain_text, length: 800) %>
    <%= link_to t('keep_reading'), group_blog_post_url(@group, blog_post) %>
    <div class="clearboth"></div>
  </div>

  <div class="blogPostFooter">
    <div class="blogPostPostedAt text-sm text-base-content/60">
      <% name = link_to((avatar(blog_post.user, size: 15, cert: false) + blog_post.user.fullname), blog_post.user) %>
      <%= raw t('pages.blog_posts.list_elements.inserted', name: name, date: (l blog_post.created_at)) %>
      |
      <span class="blogComments">
        <%= link_to t('pages.blog_posts.view.comments', count: blog_post.blog_comments_count), group_blog_post_url(@group, blog_post) %>
      </span>
    </div>
    <% if ::Configuration::socialnetwork_active %>
      <div class="post_buttons mt-2">
        <a href="https://twitter.com/share" class="twitter-share-button" data-lang="en" data-text="<%= t('twitter.share.blog_post', app: APP_SHORT_NAME, tags: blog_post.tags.for_twitter) %>" data-url="<%= group_blog_post_url(@group, blog_post) %>">Tweet</a>
        <div class="fb-like" data-href="<%= group_blog_post_url(@group, blog_post) %>" data-width="450" data-layout="button_count" data-show-faces="true" data-likeable_type="<%= blog_post.class.class_name %>" data-likeable_id="<%= blog_post.id %>" data-send="true"></div>
      </div>
    <% end %>
  </div>

  <% unless blog_post.tags.blank? %>
    <div class="blogPostTags mt-2">
      <span class="tag_label font-semibold">Tags: </span>
      <span class="tags_list"><%= raw blog_post.tags_with_links %></span>
    </div>
  <% end %>
  <div style="clear: both;"></div>
</div>
