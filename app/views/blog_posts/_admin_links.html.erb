<% if can? :edit, @blog %>
  <div class="card bg-base-200 p-4 mb-4">
    <div class="flex flex-col gap-2">
      <%= link_to new_blog_blog_post_path(@blog), class: 'btn btn-success btn-sm' do %>
        <i class="fa-solid fa-plus"></i>
        <%= t('pages.blog_posts.new_button') %>
      <% end %>
      <%= link_to drafts_blog_blog_posts_path(@blog), class: 'btn btn-sm' do %>
        <i class="fa-solid fa-file-lines"></i>
        <%= t('pages.blog_posts.drafts_button') %>
      <% end %>
      <%= link_to @blog, class: 'btn btn-sm' do %>
        <i class="fa-solid fa-file-lines"></i>
        <%= t('pages.blog_posts.published_button') %>
      <% end %>
      <%= link_to edit_blog_path(@blog), class: 'btn btn-sm' do %>
        <i class="fa-solid fa-pencil"></i>
        <%= t('pages.blogs.show.edit_button') %>
      <% end %>
      <%= link_to @blog, data: { turbo_method: :delete }, class: 'btn btn-error btn-sm', data: { turbo_confirm: t('blog.delete.confirm_message', count: @blog.blog_posts.count) } do %>
        <i class="fa-solid fa-trash"></i>
        <%= t('buttons.delete') %>
      <% end %>
    </div>
  </div>
<% end %>
