<% @page_title = 'Pannello amministrazione' %>
<% if is_admin? %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%= button_to 'Ricalcola ranking utenti', calculate_rankings_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Ricalcola stato proposte', change_proposals_state_admin_panel_path, method: :post, class: 'btn btn-sm', title: 'Verifica lo stato di tutte le proposte in votazione. Se il termine è scaduto e non sono state elaborate, le elabora' %>
    <%= button_to 'Aggiorna sitemap', write_sitemap_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Cancella vecchie notifiche', delete_old_notifications_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Mailer Test', test_mailer_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Scheduler Test', test_scheduler_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Test exceptions', test_exceptions_admin_panel_path, method: :post, class: 'btn btn-sm' %>
    <%= button_to 'Calcola affinità Utenti-Gruppi', calculate_user_group_affinity_admin_panel_path, method: :post, class: 'btn btn-sm' %>
  </div>

  <div class="card bg-base-200 p-4 mb-4">
    <h3 class="text-lg font-bold mb-2">Alert Test</h3>
    <%= form_with url: test_notification_admin_panel_path, method: :post do |f| %>
      <%= f.label :alert_id, 'Alert ID' %>
      <%= f.text_field :alert_id, class: 'input input-bordered w-full max-w-xs' %>
      <%= f.submit 'Send', class: 'btn btn-sm mt-2' %>
    <% end %>
  </div>

  <%= render 'admin/block_users' %>
<% end %>
