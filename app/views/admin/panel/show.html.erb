<% @page_title = 'Pannello amministrazione' %>
<% if is_admin? %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%= link_to 'Ricalcola ranking utenti', calculate_rankings_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Ricalcola stato proposte', change_proposals_state_admin_panel_path, class: 'btn btn-sm', title: 'Verifica lo stato di tutte le proposte in votazione. Se il temrine è scaduto e non sono state elaborate, le elabora' %>
    <%= link_to 'Aggiorna sitemap', write_sitemap_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Cancella vecchie notifiche', delete_old_notifications_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Redis Test', test_redis_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Scheduler Test', test_scheduler_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Test exceptions', test_exceptions_admin_panel_path, class: 'btn btn-sm' %>
    <%= link_to 'Calcola affinità Utenti-Gruppi', calculate_user_group_affinity_admin_panel_path, class: 'btn btn-sm' %>
  </div>

  <div class="card bg-base-200 p-4 mb-4">
    <h3 class="text-lg font-bold mb-2">Alert Test</h3>
    <%= form_tag "/admin/test_notification/" do %>
      <%= label_tag 'Alert ID' %>
      <%= text_field_tag 'alert_id', nil, class: 'input input-bordered w-full max-w-xs' %>
      <%= submit_tag 'Send', class: 'btn btn-sm mt-2' %>
    <% end %>
  </div>

  <%= render 'admin/block_users' %>
<% end %>
