.card
  h3
    | Lock users
  = form_tag block_admin_users_path do
    = label_tag 'Blocca utente'
    = text_field_tag 'user_id'
    = submit_tag 'Vai!', class: 'btn'
.card
  h3
    = 'Elenco utenti bloccati'
  ul
    - User.blocked.each do |user|
      li
        = link_to "#{user.id}: #{user.blocked_name} #{user.blocked_surname} (#{user.email})", user
        = link_to unblock_admin_user_path(user) do
          i.fa-solid.fa-unlock
          = t('buttons.unlock')