<%= form_for newsletter, url: publish_admin_newsletter_path(newsletter) do |f| %>
  <%= f.select :receiver, { admin: 'admin', tutti: 'all', 'account non confermato' => 'not_confirmed', test: 'test' }, {}, class: 'select select-bordered' %>
  <%= f.submit t('buttons.send'), class: 'btn btn-sm' %>
<% end %>
