- @newsletters.each do |newsletter|
  .card

  .row

  .columns
    = newsletter.subject
    = sanitize truncate_html(newsletter.body, length: 100, omission: '...')
  .row

  .columns
    = render 'publish_form', newsletter: newsletter
  = link_to t('buttons.edit'), edit_admin_newsletter_path(newsletter), class: 'btn'
  = link_to t('buttons.show'), admin_newsletter_path(newsletter), class: 'btn'
  = link_to t('buttons.preview'), preview_admin_newsletter_path(newsletter), class: 'btn'
= link_to t('buttons.new_newsletter'), new_admin_newsletter_path, class: 'btn blue'