<%= simple_form_for [@blog_post.blog, @blog_post, blog_comment], remote: true do |f| %>
  <%= f.error_notification %>
  <%= f.input :body, label: t('pages.proposals.show.add_comment'), html_input: { class: 'blogNewCommentField', rows: 5, cols: 70 } %>
  <%= f.submit t('pages.blog_comments.new.insert_comment'), data: { disable_with: t('loading') }, class: 'btn btn-success' %>
<% end %>

