<div class="sidebar-nav flex min-h-full flex-col bg-base-100 border-r-2 border-base-content/15 is-drawer-close:w-[4.5rem] is-drawer-open:w-64 transition-all duration-200">

  <%# Logo %>
  <%= link_to root_path, class: "flex items-center gap-3 px-4 min-h-16 border-b-2 border-base-content/10 is-drawer-close:justify-center is-drawer-close:px-0" do %>
    <div class="w-9 h-9 bg-primary flex items-center justify-center shrink-0">
      <i class="fa-solid fa-landmark text-primary-content text-base"></i>
    </div>
    <span class="font-extrabold text-lg tracking-tight is-drawer-close:hidden"><%= APP_SHORT_NAME %></span>
  <% end %>

  <%# Nav %>
  <div class="px-2 pt-5">
    <p class="text-[9px] font-bold text-base-content/30 uppercase tracking-widest mb-2 px-3 is-drawer-close:hidden"><%= t('pages.sidebar.overview', default: 'Panoramica') %></p>
    <ul class="menu w-full gap-0.5">
      <li>
        <%= link_to home_path, class: "#{current_page?(home_path) || current_page?(root_path) ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": "Dashboard" do %>
          <i class="fa-solid fa-gauge w-6 text-center text-lg"></i>
          <span class="is-drawer-close:hidden">Dashboard</span>
        <% end %>
      </li>
      <% if current_user %>
        <li>
          <%= link_to home_path, class: "text-base-content/60 hover:bg-base-200 hover:text-base-content is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.messages', default: 'Messaggi') do %>
            <i class="fa-solid fa-envelope w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.messages', default: 'Messaggi') %></span>
          <% end %>
        </li>
      <% end %>
      <li>
        <%= link_to proposals_path, class: "#{controller_name == 'proposals' ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.proposals', default: 'Proposte') do %>
          <i class="fa-solid fa-file-lines w-6 text-center text-lg"></i>
          <span class="is-drawer-close:hidden"><%= t('pages.sidebar.proposals', default: 'Proposte') %></span>
        <% end %>
      </li>
      <% if current_user && current_user.groups.any? %>
        <li data-controller="sidebar-menu"
            data-sidebar-menu-open-value="<%= @group.present? ? 'true' : 'false' %>">
          <button data-action="click->sidebar-menu#toggle"
                  class="w-full <%= controller_name == 'groups' ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content' %> flex items-center px-3 py-2 text-sm gap-2 is-drawer-close:justify-center is-drawer-close:tooltip is-drawer-close:tooltip-right"
                  data-tip="<%= t('pages.sidebar.groups', default: 'Gruppi') %>">
            <i class="fa-solid fa-users w-6 text-center text-lg shrink-0"></i>
            <span class="is-drawer-close:hidden flex-1 text-left"><%= t('pages.sidebar.groups', default: 'Gruppi') %></span>
            <i class="fa-solid fa-chevron-right text-xs is-drawer-close:hidden transition-transform duration-200"
               data-sidebar-menu-target="arrow"></i>
          </button>
          <ul data-sidebar-menu-target="submenu"
              style="max-height: 0; overflow: hidden; transition: max-height 0.25s ease;"
              class="is-drawer-close:hidden pl-8 mt-0.5 space-y-0.5">
            <% current_user.groups.limit(6).each do |g| %>
              <li>
                <%= link_to g.name, group_path(g),
                    class: "block px-3 py-1.5 text-sm #{@group&.id == g.id ? 'text-primary font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} truncate" %>
              </li>
            <% end %>
            <% if current_user.groups.count > 6 %>
              <li>
                <%= link_to t('pages.sidebar.all_groups', default: 'Tutti i gruppi →'), groups_path,
                    class: 'block px-3 py-1.5 text-xs text-primary font-bold hover:underline' %>
              </li>
            <% end %>
          </ul>
        </li>
      <% else %>
        <li>
          <%= link_to groups_path, class: "#{controller_name == 'groups' ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.groups', default: 'Gruppi') do %>
            <i class="fa-solid fa-users w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.groups', default: 'Gruppi') %></span>
          <% end %>
        </li>
      <% end %>
      <li>
        <%= link_to events_path, class: "#{controller_name == 'events' ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.events', default: 'Eventi') do %>
          <i class="fa-solid fa-calendar w-6 text-center text-lg"></i>
          <span class="is-drawer-close:hidden"><%= t('pages.sidebar.events', default: 'Eventi') %></span>
        <% end %>
      </li>
      <li>
        <%= link_to open_space_path, class: "#{current_page?(open_space_path) ? 'bg-primary text-primary-content font-semibold' : 'text-base-content/60 hover:bg-base-200 hover:text-base-content'} is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('open_space') do %>
          <i class="fa-solid fa-earth-americas w-6 text-center text-lg"></i>
          <span class="is-drawer-close:hidden"><%= t('open_space') %></span>
        <% end %>
      </li>
    </ul>
  </div>

  <% if current_user %>
    <%# Azioni rapide %>
    <div class="px-2 pt-5">
      <p class="text-[9px] font-bold text-base-content/30 uppercase tracking-widest mb-2 px-3 is-drawer-close:hidden"><%= t('pages.sidebar.quick_actions', default: 'Crea') %></p>
      <ul class="menu w-full gap-0.5">
        <li>
          <%= link_to new_proposal_path, class: "text-base-content/60 hover:bg-base-200 hover:text-base-content is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.new_proposal', default: 'Nuova proposta') do %>
            <i class="fa-solid fa-plus w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.new_proposal', default: 'Nuova proposta') %></span>
          <% end %>
        </li>
        <li>
          <%= link_to new_group_path, class: "text-base-content/60 hover:bg-base-200 hover:text-base-content is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.new_group', default: 'Nuovo gruppo') do %>
            <i class="fa-solid fa-user-group w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.new_group', default: 'Nuovo gruppo') %></span>
          <% end %>
        </li>
        <li>
          <%= link_to new_event_path, class: "text-base-content/60 hover:bg-base-200 hover:text-base-content is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.new_event', default: 'Nuovo evento') do %>
            <i class="fa-solid fa-calendar-plus w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.new_event', default: 'Nuovo evento') %></span>
          <% end %>
        </li>
      </ul>
    </div>
  <% end %>

  <%# Bottom %>
  <div class="mt-auto px-2 pb-4 pt-4 border-t-2 border-base-content/10">
    <ul class="menu w-full gap-0.5">
      <% if current_user %>
        <li>
          <%= link_to user_path(current_user), class: "text-base-content/60 hover:bg-base-200 is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.sidebar.settings', default: 'Impostazioni') do %>
            <i class="fa-solid fa-gear w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.sidebar.settings', default: 'Impostazioni') %></span>
          <% end %>
        </li>
        <li>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "text-error hover:bg-error/10 is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.header.menu.logout') do %>
            <i class="fa-solid fa-right-from-bracket w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.header.menu.logout') %></span>
          <% end %>
        </li>
      <% else %>
        <li>
          <%= link_to new_user_session_path, class: "text-base-content/60 hover:bg-base-200 is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.header.login') do %>
            <i class="fa-solid fa-right-to-bracket w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.header.login') %></span>
          <% end %>
        </li>
        <li>
          <%= link_to new_registration_path(:user), class: "text-primary hover:bg-primary/10 is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:justify-center", "data-tip": t('pages.header.menu.registration_button') do %>
            <i class="fa-solid fa-user-plus w-6 text-center text-lg"></i>
            <span class="is-drawer-close:hidden"><%= t('pages.header.menu.registration_button') %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
