<!DOCTYPE html>
<% html_attrs = { 'xml:lang' => I18n.locale, 'lang' => I18n.locale }.merge(yield(:html_options).is_a?(Hash) ? yield(:html_options) : {}) %>
<html <%= html_attrs.map { |k, v| "#{k}=\"#{v}\"" }.join(' ') %> data-controller="theme">
<head>
  <title><%= (@page_title || t('open_space')) + ' - ' + APP_SHORT_NAME %></title>
  <%= render 'layouts/head' %>
</head>
<body class="bg-base-100" data-page="<%= body_page_name %>">
  <%= render partial: "layouts/header" %>

  <% if content_for?(:left_panel) %>
    <div class="drawer lg:drawer-open pt-16">
      <input id="sidebar-drawer" type="checkbox" class="drawer-toggle">
      <div class="drawer-content flex flex-col min-h-[calc(100vh-4rem)]">
        <main class="flex-1 p-4 lg:p-6">
          <div id="flash_messages">
            <%= render partial: 'layouts/flash', locals: { flash: flash } %>
          </div>
          <%= render partial: 'layouts/tutorials' %>
          <%= yield %>
        </main>
        <%= render partial: "layouts/footer" %>
      </div>
      <div class="drawer-side">
        <label class="drawer-overlay" for="sidebar-drawer"></label>
        <aside class="w-72 min-h-full bg-base-200 pt-4 px-2">
          <%= yield :left_panel %>
        </aside>
      </div>
    </div>
  <% else %>
    <div class="pt-16 flex flex-col min-h-[calc(100vh-4rem)]">
      <main class="flex-1 container mx-auto p-4 lg:p-6">
        <div id="flash_messages">
          <%= render partial: 'layouts/flash', locals: { flash: flash } %>
        </div>
        <%= render partial: 'layouts/tutorials' %>
        <%= yield %>
      </main>
      <%= render partial: "layouts/footer" %>
    </div>
  <% end %>

  <%= render partial: "fragments/loading" %>
  <div id="privacy_modal"></div>
  <div id="terms_modal"></div>
  <div id="message_modal"></div>
</body>
</html>
