<!DOCTYPE html>
<% html_attrs = { 'xml:lang' => I18n.locale, 'lang' => I18n.locale }.merge(yield(:html_options).is_a?(Hash) ? yield(:html_options) : {}) %>
<html <%= html_attrs.map { |k, v| "#{k}=\"#{v}\"" }.join(' ') %> data-controller="theme">
<head>
  <%# FOUC prevention: applica il tema salvato PRIMA che il CSS carichi, evitando il flash di tema sbagliato %>
  <script>(function(){var t=localStorage.getItem('theme')||'nord';document.documentElement.setAttribute('data-theme',t);}());</script>
  <title><%= (@page_title || t('open_space')) + ' - ' + APP_SHORT_NAME %></title>
  <%= render 'layouts/head' %>
</head>
<body class="min-h-screen bg-base-200 opacity-0" data-page="<%= body_page_name %>">

  <div class="drawer lg:drawer-open">
    <input id="sidebar-drawer" type="checkbox" class="drawer-toggle hidden" />

    <%# ===== DRAWER CONTENT (navbar + page) ===== %>
    <div class="drawer-content flex flex-col">

      <%# Navbar %>
      <%= render 'layouts/top_menu' %>

      <%# Page header strip (opzionale, configurato dalle singole view via content_for :page_header) %>
      <%= yield(:page_header) if content_for?(:page_header) %>

      <%# Page content %>
      <div class="max-w-[1400px] mx-auto px-4 lg:px-8 py-6 lg:py-8 w-full">
        <div id="flash_messages">
          <%= render partial: 'layouts/flash', locals: { flash: flash } %>
        </div>
        <%= render partial: 'layouts/tutorials' %>
        <%= yield %>
      </div>

      <%# Footer %>
      <%= render partial: "layouts/footer" %>
    </div>

    <%# ===== DRAWER SIDEBAR ===== %>
    <div class="drawer-side is-drawer-close:overflow-visible z-40">
      <label for="sidebar-drawer" aria-label="chiudi sidebar" class="drawer-overlay"></label>
      <%= render 'layouts/sidebar' %>
    </div>

  </div>

  <%# ===== RIGHT DRAWER (filtri — contenuto da content_for :filter_drawer) ===== %>
  <% if content_for?(:filter_drawer) %>
    <div id="right-drawer"
         data-controller="right-drawer"
         class="fixed top-0 right-0 h-full w-80 bg-base-100 border-l-2 border-base-content/15 z-50 translate-x-full transition-transform duration-300 overflow-y-auto"
         aria-hidden="true">
      <div class="flex items-center justify-between p-4 border-b-2 border-base-content/15 sticky top-0 bg-base-100 z-10">
        <span class="font-bold text-sm"><%= t('pages.proposals.index.filters', default: 'Filtri') %></span>
        <button data-action="right-drawer#close" class="btn btn-ghost btn-sm btn-circle">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div class="p-4 space-y-3">
        <%= yield(:filter_drawer) %>
      </div>
    </div>
    <div data-right-drawer-target="overlay"
         class="fixed inset-0 bg-base-content/30 z-40 hidden"
         data-action="click->right-drawer#close"></div>
  <% end %>

  <%= render partial: "fragments/loading" %>
  <div id="privacy_modal"></div>
  <div id="terms_modal"></div>
  <div id="message_modal"></div>

  <script>
    function revealBody() {
      document.body.classList.remove('opacity-0');
      document.body.classList.add('transition-opacity', 'duration-150');
    }
    // DOMContentLoaded: primo caricamento pagina
    document.addEventListener('DOMContentLoaded', revealBody);
    // turbo:load: ogni navigazione Turbo Drive (body viene sostituito e opacity-0 ripristinato)
    document.addEventListener('turbo:load', revealBody);
  </script>
</body>
</html>
