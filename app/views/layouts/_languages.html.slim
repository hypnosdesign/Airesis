#language.reveal-modal.bg-white.rounded-lg.shadow-2xl.p-6 data-reveal=true
  dl.tabs.flex.border-b.border-gray-200.mb-4 data-tab=true
    dd.active.mr-4
      a.inline-block.py-2.px-4.text-blue-600.border-b-2.border-blue-600.font-medium href="#panel1" title="Europe" Europe
    dd.mr-4
      a.inline-block.py-2.px-4.text-gray-500.hover:text-blue-600.font-medium href="#panel2" title="America" America
    dd.mr-4
      a.inline-block.py-2.px-4.text-gray-500.hover:text-blue-600.font-medium href="#panel3" title="Asia" Asia
    dd.mr-4
      a.inline-block.py-2.px-4.text-gray-500.hover:text-blue-600.font-medium href="#panel4" title="Africa" Africa
    dd
      a.inline-block.py-2.px-4.text-gray-500.hover:text-blue-600.font-medium href="#panel5" title="Oceania" Oceania
  
  dl.accordion data-accordion=true
    .tabs-content
      #panel1.content.active.p-4
