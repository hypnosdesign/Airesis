          li = flag_for('Italy', 'it-IT')
          li = flag_for('Deutschland', 'de-DE')
          li = flag_for('România', 'ro-RO')
          li = flag_for('España', 'es-ES')
          li = flag_for('Portugal', 'pt-PT')
          li = flag_for('Greece', 'el-GR')
          li = flag_for('United Kingdom', 'en-GB')
          li = flag_for('Ireland', 'en-IE')
          li = flag_for('Serbia (Cyrillic)', 'sr-SP')
          li = flag_for('Serbia (Latin)', 'sr-CS')
          li = flag_for('Serbo-Croatian', 'sh-HR')
          li = flag_for('Bosnian', 'bs-BA')
          li = flag_for('Montenegrin (Latin)', 'me-ME')
          li = flag_for('Russia','ru-RU')
      
