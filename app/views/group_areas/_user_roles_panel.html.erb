<% if @group_area.area_participations.count > 0
 %><table id="roles_table">
<thead>

</thead></table><th>
<%= ::Temple::Utils.escape_html((t('pages.groups.edit_permissions.user_title'))) %>
</th><th>
<%= ::Temple::Utils.escape_html((t('pages.groups.edit_permissions.role_title'))) %>
</th><tbody>
<% @group_area.area_participations.each do |gp|
 %><tr>
<td>
<%= ::Temple::Utils.escape_html((avatar(gp.user, size: 16))) %>
<%= ::Temple::Utils.escape_html((link_to gp.user.fullname, gp.user)) %>
</td><td>
<%= ::Temple::Utils.escape_html((select_tag "user_role", options_from_collection_for_select(@group_area.area_roles,:id,:name,gp.area_role.id), "data-user_id" => gp.user.id, class: "user_role_changer")) %>
</td></tr><% end %></tbody><% else
 %><h4>
<%= ::Temple::Utils.escape_html((t('pages.groups.edit_permissions.no_users_yet'))) %>
</h4><% end %>
