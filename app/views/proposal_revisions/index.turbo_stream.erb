<%= turbo_stream.replace "revisions_modal" do %>
  <dialog id="revisions_modal" data-controller="modal" class="modal">
    <div class="modal-box shadow-brutal border-2 border-base-content max-w-3xl max-h-[80vh] overflow-y-auto">
      <%= render "proposal_revisions/panel" %>
    </div>
    <form method="dialog" class="modal-backdrop" data-action="click->modal#backdropClose">
      <button>close</button>
    </form>
  </dialog>
<% end %>
