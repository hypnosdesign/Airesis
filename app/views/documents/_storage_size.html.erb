<% percentage = ((@group.actual_storage_size.to_f / @group.max_storage_size.to_f) * 100).round(2) %>
<div class="card bg-base-200 p-4">
  <h4 class="font-bold"><%= t('pages.groups.documents.storage_size') %></h4>
  <div class="text-2xl font-bold"><%= percentage %>%</div>
  <div class="mt-2">
    <progress class="progress progress-primary w-full" value="<%= percentage %>" max="100"></progress>
  </div>
  <ul class="mt-2 text-sm">
    <li>
      <%= t('pages.groups.documents.max_storage_size') %>:
      <b><%= (@group.max_storage_size.to_f / 1024).round(2) %> MB</b>
    </li>
    <li>
      <%= t('pages.groups.documents.current_storage_usage') %>:
      <b><%= (@group.actual_storage_size.to_f / 1024).round(2) %> MB</b>
    </li>
  </ul>
</div>
