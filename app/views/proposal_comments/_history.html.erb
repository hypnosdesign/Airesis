<div class="flex flex-wrap w-full">
  <div class="w-full">
    <% @proposal_comment.versions.each do |version| %>
      <div class="card bg-base-200 p-4" data-version-id="<%= version.id %>" data-version>
        <span>
          <%= parsed_content(version.reify, @proposal.is_anonima?) if version.reify %>
        </span>
        <div></div>
        <div class="baloon-footer" title="<%= l(version.created_at) %>">
          <%= time_in_words(version.created_at) %>
        </div>
      </div>
    <% end %>
  </div>
</div>
<div class="card bg-base-200 p-4" style="display: none;">
  <span>
    <%= parsed_content(@proposal_comment, @proposal.is_anonima?) %>
  </span>
</div>
<a class="close-reveal-modal">&times;</a>
<script type="text/javascript">
  var dmp = new diff_match_patch(); $('.card[data-version]').each(function () { var text1 = $(this).find('span').text(); var text2 = $(this).next('.card').find('span').text(); dmp.Diff_Timeout = 0; dmp.Diff_EditCost = 4; var d = dmp.diff_main(text1, text2); dmp.diff_cleanupEfficiency(d); var ds = dmp.diff_prettyHtml(d); $(this).find('span').html(ds); }); disegnaCountdown();
</script>
