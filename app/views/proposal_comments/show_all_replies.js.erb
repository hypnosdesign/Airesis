<% @replies.each_with_index do |reply,i|
 %> $('#
<%= ::Temple::Utils.escape_html((@proposal_comment.id)) %>
_replies').append('
<%= ::Temple::Utils.escape_html((j render(partial: 'proposals/reply', locals: {reply: reply, hide: false}))) %>
'); 
<% if (i < @replies.length - 1) && (version = @proposal_comment.versions.where(['created_at between ? and ?',@replies[i].created_at, @replies[i+1].created_at]).first)
 %> $('#
<%= ::Temple::Utils.escape_html((@proposal_comment.id)) %>
_replies').append('
<div class="panel callout comment_update_divider">
<%= ::Temple::Utils.escape_html((j raw 'updated on ' + time_in_words(version.created_at))) %>
</div>'); 
<% end; end; if (version = (@proposal_comment.versions.where(['created_at > ?',@replies.last.created_at]).first))
 %> $('#
<%= ::Temple::Utils.escape_html((@proposal_comment.id)) %>
_replies').append('
<div class="panel callout comment_update_divider">
<%= ::Temple::Utils.escape_html((j raw 'updated on ' + time_in_words(version.created_at))) %>
</div>'); 
<% end %> $("#
<%= ::Temple::Utils.escape_html((@proposal_comment.id)) %>
_show").hide("slide", { direction: "up" }, 600); $('#
<%= ::Temple::Utils.escape_html((@proposal_comment.id)) %>
_replies').show("slide", { direction: "up" }, 600); disegnaCountdown(); 
