<%= ::Temple::Utils.escape_html(("in \"#{@comment.paragraph.section.title}\"" if @comment.paragraph)) %>
</div><div style="clear:both;">
</div></div></div><p>
<%= ::Temple::Utils.escape_html((raw t('mailer.unintegrated_contribute.view_proposal_2', click_here: (link_to t('mailer.unintegrated_contribute.verify'), @alert_url)))) %>
