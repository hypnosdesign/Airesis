<% @proposal = Proposal.find(@data[:proposal_id])
@username = @data[:username]
@comment = @proposal.contributes.find(@data[:comment_id])
@alert_url = check_alert_url(@alert)
 %><p>
<%= ::Temple::Utils.escape_html((raw t('mailer.unintegrated_contribute.view_proposal', click_here: (link_to @proposal.title, @alert_url)))) %>
