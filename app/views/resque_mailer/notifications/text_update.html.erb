<% @proposal = Proposal.find(@data[:proposal_id])
@alert_url = check_alert_url(@alert, host: @alert.user.locale.host, l: @alert.user.locale.lang)
contributes = []
proposal_revisions = @proposal.proposal_revisions.where(ProposalRevision.arel_table[:id].gteq(ProposalRevision.find(@data[:revision_id]).id))
 %><h3>
 Hi, 
<%= ::Temple::Utils.escape_html((@alert.user.fullname)) %>
</h3><p class="lead">
<%= ::Temple::Utils.escape_html((raw t('mailer.text_update.view_proposal', proposal: (link_to @proposal.title, @alert_url), count: proposal_revisions.count))) %>
<br />
</p><% proposal_revisions.each do |proposal_revision|
 %><div class="card">
<% proposal_revision.section_histories.each do |section_history|
 %><div class="proposal_main">
<h5>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.sections.added')}: " if section_history.added)) %>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.sections.removed')}: " if section_history.removed)) %>
<%= ::Temple::Utils.escape_html((section_history.title)) %>
</h5> <div class="proposal_content
<%= ::Temple::Utils.escape_html((section_history.removed ? 'ice-del' : '')) %>
<%= ::Temple::Utils.escape_html((section_history.added ? 'ice-ins' : '')) %>
">
<p>
<%= ::Temple::Utils.escape_html((sanitize(section_history.paragraphs.first.parsed_content(@proposal.is_anonima?)))) %>
</p></div><% end %></div><% if proposal_revision.solution_histories.size > 0
proposal_revision.solution_histories.includes(section_histories: :paragraphs).order('section_histories.seq').each_with_index do |solution_history, i|
 %><div class="solution_main">
<h5>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.solutions.added')}: " if solution_history.added)) %>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.solutions.removed')}: " if solution_history.removed)) %>
<%= ::Temple::Utils.escape_html((raw t("pages.proposals.edit.new_solution_title.#{@proposal.proposal_type.name.downcase}", num: i+1))) %>
<%= ::Temple::Utils.escape_html(("#{solution_history.title}")) %>
</h5> <div class="sol_content
<%= ::Temple::Utils.escape_html((solution_history.removed ? 'ice-del' : '')) %>
<%= ::Temple::Utils.escape_html((solution_history.added ? 'ice-ins' : '')) %>
">
<% solution_history.section_histories.each do |section|
 %><div class="proposal_main">
<h5>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.sections.added')}: " if section.added)) %>
<%= ::Temple::Utils.escape_html(("#{t('pages.proposal_histories.sections.removed')}: " if section.removed)) %>
<%= ::Temple::Utils.escape_html((section.title)) %>
</h5> <div class="proposal_content
<%= ::Temple::Utils.escape_html((section.removed ? 'ice-del' : '')) %>
<%= ::Temple::Utils.escape_html((section.added ? 'ice-ins' : '')) %>
">
<%= ::Temple::Utils.escape_html((sanitize(section.paragraphs.first.parsed_content(@proposal.is_anonima?)))) %>
</div><% end %></div><% end; end; contributes += proposal_revision.contributes.where('proposal_comments.user_id = ?', @alert.user.id)
end; if contributes.count > 0
 %><p>
<%= ::Temple::Utils.escape_html((t('mailer.text_update.integrated_contributes'))) %>
</p><% contributes.each do |contribute|
 %> <div id="comment
<%= ::Temple::Utils.escape_html((contribute.id)) %>
" style="padding: 20px 0 0;clear: both;"> 
<div style="float: left;margin: 0px 5px 5px 0px;">
<%= ::Temple::Utils.escape_html((avatar(contribute.user, size: 40, url: true))) %>
</div><div style="border: 1px solid #CCCCCC;border-radius: 3px 3px 0px 0px;margin-left: 50px;color: #333333;">

</div><div>

</div><div style="word-wrap: break-word;margin: 5px;">
<%= ::Temple::Utils.escape_html((parsed_content(contribute, @proposal.is_anonima?))) %>
</div><div style="font-size: 0.9em;margin-top: 5px;margin-left: 5px;margin-bottom: 2px;color: #999999;float: left;">
<% who = contribute.user.fullname
 %><%= ::Temple::Utils.escape_html((raw t('pages.proposals.show.comment_inserted_by', when: (l contribute.created_at), who: who))) %>
<%= ::Temple::Utils.escape_html(("in \"#{contribute.paragraph.section.title}\"" if contribute.paragraph)) %>
</div><div style="clear:both;">
</div><% end %><div class="callout">
<p class="panel">
<%= ::Temple::Utils.escape_html((raw t('mailer.text_update.view_proposal_2', click_here: (link_to t('mailer.text_update.connect', name: APP_SHORT_NAME), @alert_url)))) %>
</p></div><% end %>
