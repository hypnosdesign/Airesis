<div class="title clearfix">
  <span class="left">
    <%= t('pages.home.index.most_used_tags') %>
  </span>
  <%= link_to t('pages.home.index.show_tags'), tags_path, class: 'btn right' %>
</div>
<div class="scrollable">
  <% @tags.each do |tag| %>
    <span class="badge tag">
      <a href="<%= tag_path tag.text %>"><%= tag.text %></a>
    </span>
  <% end %>
</div>
