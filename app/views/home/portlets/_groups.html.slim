.title
  |  I gruppi 
#group_portlet
  - @groups = current_user.groups
  - @groups.each do |group|
    .groupcontainer

    .groupImg24
      = group.group_image_tag 25
    .group
      = link_to group.name, group
- @following = current_user.followed_groups
- @following.each do |group|
  .groupcontainer

  .groupImg24
    = group.group_image_tag 25
  .group
    = link_to group.name, group
  = "Non partecipi a nessun gruppo ancora" if @groups.empty? && @following.empty?