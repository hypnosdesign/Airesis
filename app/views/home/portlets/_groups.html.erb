<div class="title">
 I gruppi 
</div><div id="group_portlet">
<% @groups = current_user.groups
@groups.each do |group|
 %><div class="groupcontainer">

</div><div class="groupImg24">
<%= ::Temple::Utils.escape_html((group.group_image_tag 25)) %>
</div><div class="group">
<%= ::Temple::Utils.escape_html((link_to group.name, group)) %>
</div><% end %></div><% @following = current_user.followed_groups
@following.each do |group|
 %><div class="groupcontainer">

</div><div class="groupImg24">
<%= ::Temple::Utils.escape_html((group.group_image_tag 25)) %>
</div><div class="group">
<%= ::Temple::Utils.escape_html((link_to group.name, group)) %>
</div><%= ::Temple::Utils.escape_html(("Non partecipi a nessun gruppo ancora" if @groups.empty? && @following.empty?)) %>
<% end %>
