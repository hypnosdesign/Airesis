<% if params[:page]
 %> $('#blogs_list').append("
<%= ::Temple::Utils.escape_html((j (render partial: "blog", collection: @blogs))) %>
"); 
<% else
 %> $('#blogs_list').fadeOut('slow', function () { 
<% if @blogs.count > 0
 %> $('#blogs_list').html("
<%= ::Temple::Utils.escape_html((j (render partial: "blog", collection: @blogs))) %>
"); 
<% else
 %> $('#blogs_list').html("
<h2>
<%= ::Temple::Utils.escape_html((j t('pages.blogs.index.no_results'))) %>
</h2>"); 
<% end %> $('#blogs_list').fadeIn(); }) 
<% end %> $('#more_blogs_container').html("
<%= ::Temple::Utils.escape_html((j (render partial: 'more_blogs'))) %>
"); 
<% if params[:back]
 %> $('#search').val('
<%= ::Temple::Utils.escape_html((params[:search])) %>
'); 
<% else
 %> window.history.pushState(null,"",'
<%= ::Temple::Utils.escape_html((j raw request.url + '&_ajax=true')) %>
'); everPushedSomething = 'pushed it real good'; 
<% end %> if (window.innerWidth <= 1000) { $('html, body').animate({ scrollTop: $('#blogs_list').offset().top - (10 + (window.innerWidth < 1000 ? 0 : 90)) }, 2000); } 
