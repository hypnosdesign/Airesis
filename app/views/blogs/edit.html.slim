- @page_title = t('pages.blogs.edit.title', title: @blog.title)
.card
  .row
    .columns.small-12
      h2
        = t('pages.blogs.edit.title', title: @blog.title)
  = simple_form_for @blog do |f|
    .row

    .columns.small-12
      = f.error_notification
      = f.input :title, required: true
    .columns.small-12
      = link_to t('pages.blogs.edit.back_to_blog'), @blog, class: 'btn backButton'
      = f.button :button, class: 'btn blue' do
        i.fa-solid.fa-floppy-disk
        = t('buttons.update')
- content_for :left_panel do
  = render 'blog_posts/admin_links'
  = render 'blogs/left_panel'