<% @extend = true %>
<% @page_title = t('pages.blogs.index.find_blog_label') %>

<%# ===== HERO BANNER ===== %>
<div class="bg-primary text-primary-content p-6 lg:p-8 mb-6 border-2 border-base-content/15 relative overflow-hidden">
  <div class="relative z-10 max-w-xl">
    <p class="text-[11px] font-bold tracking-widest text-primary-content/50 uppercase mb-3">Blog</p>
    <h1 class="text-2xl lg:text-3xl font-extrabold leading-tight mb-2"><%= t('pages.blogs.index.find_blog_label') %></h1>
    <p class="text-primary-content/60 text-sm"><%= t('pages.blogs.index.search_description') %></p>
  </div>
  <i class="fa-solid fa-newspaper absolute right-6 lg:right-12 top-1/2 -translate-y-1/2 text-[7rem] lg:text-[9rem] text-primary-content/[0.06] hidden md:block"></i>
</div>

<%# ===== SEARCH & TAGS ===== %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <div id="blog_search_form">
    <div class="bg-base-100 border-2 border-base-content/15 p-4">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 flex items-center justify-center bg-primary/10 text-primary">
          <i class="fa-solid fa-magnifying-glass text-sm"></i>
        </div>
        <h2 class="font-bold text-sm"><%= t('buttons.search', default: 'Cerca') %></h2>
      </div>
      <%= render 'blogs/search_form' %>
    </div>
  </div>
  <div class="hidden lg:block">
    <div class="bg-base-100 border-2 border-base-content/15 p-4" data-tag-cloud>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 flex items-center justify-center bg-secondary/10 text-secondary">
          <i class="fa-solid fa-tags text-sm"></i>
        </div>
        <h2 class="font-bold text-sm">Tags</h2>
      </div>
      <div class="flex flex-wrap gap-1">
        <% @tags.each do |tag| %>
          <%= link_to tag.text, blogs_url(tag: tag.text), rel: tag.blog_posts_count, class: 'badge badge-primary badge-sm font-bold' %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# ===== BLOG GRID ===== %>
<% if @blogs.count > 0 %>
  <div id="blogs_list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    <% @blogs.each do |blog| %>
      <%= render partial: "blog", locals: { blog: blog } %>
    <% end %>
  </div>
<% else %>
  <div class="bg-base-100 border-2 border-base-content/15 p-8 text-center">
    <i class="fa-solid fa-newspaper text-4xl text-base-content/20 mb-3"></i>
    <h2 class="text-lg font-bold text-base-content/60"><%= t('pages.blogs.index.search_description') %></h2>
  </div>
<% end %>

<div id="more_blogs_container">
  <%= render partial: 'more_blogs' %>
</div>
