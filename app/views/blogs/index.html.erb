<% @extend = true
 %><h1>
<%= ::Temple::Utils.escape_html((t('pages.blogs.index.find_blog_label'))) %>
</h1><div class="row">
<div class="columns large-6" id="blog_search_form">
<div class="card">
<%= ::Temple::Utils.escape_html((render 'blogs/search_form')) %>
</div></div><div class="columns large-6 show-for-large-up">
<div class="card" data-tag-cloud="">
<% @tags.each do |tag|
 %><%= ::Temple::Utils.escape_html((link_to tag.text, blogs_url(tag: tag.text), remote: true, rel: tag.blog_posts_count, class: 'round label')) %>
<% end %></div></div></div><% if @blogs.count > 0
 %><ul class="small-block-grid-2 medium-block-grid-3 large-block-grid-4 xlarge-block-grid-5 xxlarge-block-grid-6" id="blogs_list">
<% @blogs.each do |blog|
 %><%= ::Temple::Utils.escape_html((render partial: "blog", locals: { blog: blog })) %>
<% end %></ul><% else
 %><h2>
<%= ::Temple::Utils.escape_html((t('pages.blogs.index.search_description'))) %>
</h2><% end %><div class="clearboth">
</div><div id="more_blogs_container">
<%= ::Temple::Utils.escape_html((render partial: 'more_blogs')) %>
</div><script type="text/javascript">
 function checkCharacters() { if (($('#search').val().length > 2) || ($('#interest_border').val() != '')) { return true; } else { alert('<%= ::Temple::Utils.escape_html((t('pages.blogs.index.insert_query'))) %>'); return false; } } $('#interest_border').tokenInput("<%= ::Temple::Utils.escape_html((interest_borders_path(format: :json ))) %>", { propertyToSearch: 'text', crossDomain: false, prePopulate: $('#interest_border').data("pre"), hintText: "<%= ::Temple::Utils.escape_html((t('interest_borders.hint'))) %>", noResultsText: "<%= ::Temple::Utils.escape_html((t('interest_borders.no_place_found'))) %>", searchingText: "<%= ::Temple::Utils.escape_html((t('interest_borders.searching'))) %>", preventDuplicates: true, tokenLimit: 1, allowTabOut: true }); var everPushedSomething = false; var initialUrl = location.href; $(window).bind('popstate', function (event) { var onloadPop = !everPushedSomething && location.href == initialUrl; everPushedSomething = true; if (onloadPop) { return; } $.getScript(addQueryParam(location.href, 'back', 'true')); }); $("#and").switchButton({ checked: <%= ::Temple::Utils.escape_html((params[:and] == 'on')) %>, on_label: $('<div class="switch_opt">&</div>'), off_label: $('<div class="switch_opt">||</div>'), on_title: '<%= ::Temple::Utils.escape_html((t('pages.groups.index.switchButton.all_words'))) %>', off_title: '<%= ::Temple::Utils.escape_html((t('pages.groups.index.switchButton.one_word'))) %>' }); $('.switch-button-label.on, .switch-button-label.off').qtip({ prerender: true, position: { at: 'top center', my: 'bottom center', viewport: $(window), effect: false }, style: { classes: 'qtip-dark' } }); 
</script>
