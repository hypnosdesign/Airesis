<% @extend = true %>

<h1 class="text-2xl font-bold mb-4"><%= t('pages.blogs.index.find_blog_label') %></h1>

<div class="flex flex-wrap gap-4 mb-4">
  <div id="blog_search_form" class="w-full lg:w-1/2">
    <div class="card bg-base-200 p-4">
      <%= render 'blogs/search_form' %>
    </div>
  </div>
  <div class="w-full lg:w-1/2 hidden lg:block">
    <div class="card bg-base-200 p-4" data-tag-cloud>
      <% @tags.each do |tag| %>
        <%= link_to tag.text, blogs_url(tag: tag.text), rel: tag.blog_posts_count, class: 'badge badge-outline mr-1 mb-1' %>
      <% end %>
    </div>
  </div>
</div>

<% if @blogs.count > 0 %>
  <ul id="blogs_list" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    <% @blogs.each do |blog| %>
      <%= render partial: "blog", locals: { blog: blog } %>
    <% end %>
  </ul>
<% else %>
  <h2 class="text-lg"><%= t('pages.blogs.index.search_description') %></h2>
<% end %>

<div class="clearboth"></div>

<div id="more_blogs_container">
  <%= render partial: 'more_blogs' %>
</div>

<script type="text/javascript">
  function checkCharacters() {
    var search = document.getElementById('search');
    var border = document.getElementById('interest_border');
    if ((search && search.value.length > 2) || (border && border.value !== '')) {
      return true;
    } else {
      alert('<%= t('pages.groups.index.insert_query_or_place') %>');
      return false;
    }
  }
</script>
