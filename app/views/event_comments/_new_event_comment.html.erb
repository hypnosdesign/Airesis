<div id="eventNewComment" class="eventNewComment">
  <% if !user_signed_in? %>
    <h2><%= t('pages.proposals.show.login_to_comment') %></h2>
  <% else %>
    <%= simple_form_for [@event, event_comment], remote: true do |f| %>
      <%= f.input :body, as: :text, label: t('pages.proposals.show.add_comment'), input_html: { class: 'blogNewCommentField', rows: 5, cols: 70 } %>
      <p>
        <%= f.submit t('pages.event_comments.new.insert_comment'), data: { disable_with: t('loading') }, class: 'btn btn-success' %>
      </p>
    <% end %>
  <% end %>
</div>
