<%= simple_form_for((@group.present? ? [@group, @participation_role] : @participation_role)) do |f| %>
  <%= f.input :name %>
  <%= f.input :description, as: :text %>
  <%= link_to t('buttons.cancel'), '#', class: 'btn', data: { action: 'click->modal#close' } %>
  <%= link_to t('buttons.go_back'), :back, class: 'btn', data: { back: '' } %>
  <%= f.button :button, class: 'btn btn-primary' do %>
    <i class="fa-solid fa-floppy-disk"></i>
    <%= button_name %>
  <% end %>
<% end %>
